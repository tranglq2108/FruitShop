    <div class="dark-card w-full max-w-xl p-8 rounded-2xl shadow-2xl border border-gray-700 animate-fade-in max-h-[90vh] overflow-y-auto scrollbar-thin">
        <div class="flex items-center justify-between gap-4 mb-8 border-b border-gray-700/50 pb-5">
            <h3 id="modalTitle" class="text-2xl font-bold tracking-tight theme-contrast">Thêm tài khoản</h3>
            <button type="button" class="close-modal text-gray-400 hover:text-white transition-colors"><svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12" /></svg></button>
