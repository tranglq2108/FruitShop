<div id="toastContainer" class="fixed top-4 right-4 z-[100] space-y-2"></div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            let isEditMode = false;
            let deleteTarget = null;
            let deleteType = 'single';
            let selectedExportFormat = 'excel';
            const urlParams = new URLSearchParams(window.location.search);

            // --- HELPER FUNCTIONS ---
            function showToast(msg, type = 'success') {
                const container = document.getElementById('toastContainer');
                const t = document.createElement('div');
                t.className = `dark-card px-6 py-3.5 rounded-xl border-l-4 ${type === 'success' ? 'border-blue-500' : 'border-red-500'} shadow-2xl text-white animate-fade-in mb-2 flex items-center gap-3`;
                t.innerHTML = `<span class="font-medium text-sm">${msg}</span>`;
                container.appendChild(t);
                setTimeout(() => { t.classList.add('opacity-0'); setTimeout(() => t.remove(), 500); }, 3000);
            }

            // --- UI ACTIONS ---
            const performSearch = (page = 1) => {
                urlParams.set('page', page);
                urlParams.set('searchTerm', document.getElementById('searchInput').value);
                ['fFullName', 'fEmail', 'fPhone', 'fRoleId', 'fStatus', 'fIsVerified'].forEach(id => {
                    const v = document.getElementById(id).value;
                    if (v) urlParams.set(id, v); else urlParams.delete(id);
                });
                window.location.href = `${window.location.pathname}?${urlParams.toString()}`;
            };

            document.getElementById('applyFilterBtn').onclick = () => performSearch(1);
            document.getElementById('resetFilterBtn').onclick = () => {
                document.querySelectorAll('#filterPanel input, #filterPanel select').forEach(i => i.value = '');
                performSearch(1);
            };

            const debounce = (fn, d) => { let t; return (...a) => { clearTimeout(t); t = setTimeout(() => fn(...a), d); }; };
            document.getElementById('searchInput').oninput = debounce(() => performSearch(1), 500);

            document.querySelectorAll('.sortable-header').forEach(h => {
                h.onclick = function() {
                    const col = this.dataset.column;
                    const order = (urlParams.get('sortBy') === col && urlParams.get('sortOrder') === 'asc') ? 'desc' : 'asc';
                    urlParams.set('sortBy', col);
                    urlParams.set('sortOrder', order);
                    performSearch(1);
                };
            });

            // --- CRUD ---
            document.getElementById('addBtn').onclick = () => {
                isEditMode = false;
                document.getElementById('modalTitle').innerText = "Thêm tài khoản mới";
                document.getElementById('userForm').reset();
                document.getElementById('userId').value = '';
                document.getElementById('avatarPreview').src = "https://placehold.co/120";
                document.getElementById('avatarPreview').onerror = function() { this.onerror=null; this.src='https://placehold.co/120'; };
                document.getElementById('pwdHint').classList.add('hidden');
                document.getElementById('userModal').classList.remove('hidden');
            };

            const attachEvents = () => {
                document.querySelectorAll('.editBtn').forEach(btn => {
                    btn.onclick = function() {
                        isEditMode = true;
                        const d = this.closest('tr').dataset;
                        document.getElementById('modalTitle').innerText = "Cập nhật tài khoản";
                        document.getElementById('userId').value = d.id;
                        document.getElementById('userFullName').value = d.copyFullname;
                        document.getElementById('userEmail').value = d.copyEmail;
                        document.getElementById('userPhone').value = d.copyPhone;
                        document.getElementById('userRoleId').value = d.copyRole;
                        document.getElementById('userStatus').value = d.copyStatus;
                        document.getElementById('userIsVerified').checked = d.copyVerified == "1";
                        document.getElementById('avatarPreview').src = d.copyAvatar || "https://placehold.co/120";
                        document.getElementById('avatarPreview').onerror = function() { this.onerror=null; this.src='https://placehold.co/120'; };
                        document.getElementById('pwdHint').classList.remove('hidden');
                        document.getElementById('userModal').classList.remove('hidden');
                    };
                });

                document.querySelectorAll('.viewBtn').forEach(btn => {
                    btn.onclick = function() {
                        const d = this.dataset;
                        document.getElementById('viewFullName').innerText = d.fullname;
                        document.getElementById('viewEmail').innerText = d.email;
                        document.getElementById('viewPhone').innerText = d.phone || 'Chưa cập nhật';
                        document.getElementById('viewRole').innerText = d.role;
                        document.getElementById('viewCreated').innerText = d.created;
                        document.getElementById('viewAvatar').src = d.avatar || "https://ui-avatars.com/api/?name=" + d.fullname;
                        
                        document.getElementById('viewStatus').innerHTML = d.status == "1" ? '<span class="text-green-400 font-bold">Hoạt động</span>' : '<span class="text-red-400 font-bold">Bị khóa</span>';
                        document.getElementById('viewVerified').innerHTML = d.verified == "1" ? '<span class="text-blue-400 font-bold">Đã xác thực</span>' : '<span class="text-gray-500 font-bold">Chưa xác thực</span>';
                        
                        document.getElementById('viewModal').classList.remove('hidden');
                    };
                });

                document.querySelectorAll('.deleteSingleBtn').forEach(btn => {
                    btn.onclick = function() {
                        deleteType = 'single';
                        deleteTarget = this.dataset.id;
                        document.getElementById('deleteConfirmModal').classList.remove('hidden');
                    };
                });
            };

            document.getElementById('userForm').onsubmit = function(e) {
                e.preventDefault();
                const formData = new FormData(this);
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                fetch(isEditMode ? '/Users/Update' : '/Users/Create', {
                    method: 'POST', headers: { 'RequestVerificationToken': token }, body: formData
                })
                .then(r => r.json()).then(res => {
                    if (res.success) {
                        showToast("Thành công!");
                        location.reload();
                    } else showToast(res.message, 'error');
                });
            };

            document.getElementById('confirmDeleteBtn').onclick = () => {
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                const url = deleteType === 'single' ? `/Users/Delete?id=${deleteTarget}` : '/Users/DeleteSelected';
                const body = deleteType === 'single' ? null : JSON.stringify(deleteTarget);
                
                fetch(url, { method: 'POST', headers: { 'RequestVerificationToken': token, 'Content-Type': 'application/json' }, body: body })
                .then(r => r.json()).then(res => {
                    if (res.success) { showToast(res.message); location.reload(); }
                    else showToast(res.message, 'error');
                });
            };

            // --- AVATAR PREVIEW ---
            document.getElementById('avatarFileInput').onchange = function(e) {
                if (e.target.files && e.target.files[0]) {
                    const reader = new FileReader();
                    reader.onload = (ex) => document.getElementById('avatarPreview').src = ex.target.result;
                    reader.readAsDataURL(e.target.files[0]);
                }
            };

            // --- EXPORT ---
            document.getElementById('exportBtn').onclick = () => {
                document.getElementById('exportSelectedCount').innerText = document.querySelectorAll('.userCheckbox:checked').length;
                document.getElementById('exportModal').classList.remove('hidden');
            };
            document.querySelectorAll('.export-fmt-btn').forEach(btn => {
                btn.onclick = function() {
                    selectedExportFormat = this.dataset.format;
                    document.querySelectorAll('.export-fmt-btn').forEach(b => b.classList.toggle('selected', b === this));
                    document.querySelectorAll('.export-fmt-btn').forEach(b => b.classList.toggle('border-green-500', b === this));
                };
            });
            document.getElementById('doExportBtn').onclick = () => {
                const scope = document.querySelector('input[name="exportScope"]:checked').value;
                let url = `/Users/Export${selectedExportFormat.charAt(0).toUpperCase() + selectedExportFormat.slice(1)}`;
                if (scope === 'selected') {
                    const ids = Array.from(document.querySelectorAll('.userCheckbox:checked')).map(cb => cb.dataset.id).join(',');
                    url += `?ids=${ids}`;
                }
                window.location.href = url;
                document.getElementById('exportModal').classList.add('hidden');
            };

            // --- INITIALIZE ---
            attachEvents();
            document.getElementById('toggleFilterBtn').onclick = () => document.getElementById('filterPanel').classList.toggle('hidden');
            document.getElementById('actionsBtn').onclick = (e) => { e.stopPropagation(); document.getElementById('actionsMenu').classList.toggle('hidden'); };
            document.addEventListener('click', () => { document.getElementById('actionsMenu').classList.add('hidden'); });
            document.querySelectorAll('.close-modal').forEach(b => b.onclick = () => b.closest('.fixed').classList.add('hidden'));
            document.getElementById('selectAll').onchange = function() { document.querySelectorAll('.userCheckbox').forEach(cb => cb.checked = this.checked); };

            // --- KEYBOARD SHORTCUTS ---
            document.addEventListener('keydown', function (e) {
                const inInput = ['INPUT', 'TEXTAREA', 'SELECT'].includes(document.activeElement.tagName);

                if (e.key === 'Escape') {
                    const openModals = document.querySelectorAll('.fixed:not(.hidden)');
                    if (openModals.length > 0) {
                        openModals.forEach(m => m.classList.add('hidden'));
                    } else if (inInput) {
                        document.activeElement.blur();
                    }
                    document.getElementById('actionsMenu')?.classList.add('hidden');
                }

                if (e.altKey) {
                    const map = {
                        'n': 'addBtn', 
                        'a': 'actionsBtn', 
                        'f': 'toggleFilterBtn',
                        's': 'searchInput', 
                        'e': 'exportBtn',
                        'k': 'copySelectedBtn', 
                        'd': 'deleteSelectedBtn',
                        'r': 'resetFilterBtn',
                        'c': 'columnConfigBtn',
                        't': 'themeToggle'
                    };
                    const key = e.key.toLowerCase();
                    if (map[key]) {
                        const btn = document.getElementById(map[key]);
                        if (btn) {
                            e.preventDefault();
                            if (key === 's') btn.focus();
                            else btn.click();
                        }
                    }
                }

                if (!inInput && e.key === '/') {
                    e.preventDefault();
                    document.getElementById('searchInput').focus();
                }
            });
        });
    </script>
}
