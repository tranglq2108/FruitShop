@model FruitShop.ViewModels.UserList
@using System.Text.Json

@{
    ViewData["Title"] = "Quản lý tài khoản";
}

<link rel="stylesheet" href="~/css/animations.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/products.css" asp-append-version="true" />
<link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.14.0/Sortable.min.js"></script>

@Html.AntiForgeryToken()

<div class="min-h-screen pt-0 px-6 pb-20">
    <!-- Header -->
    <div class="flex items-center justify-between mb-2">
        <h1 class="text-2xl font-bold tracking-tight theme-contrast">Danh sách tài khoản</h1>
        <div class="flex items-center gap-2">
            <button id="themeToggle" class="btn-theme" title="Đổi giao diện (Alt + T)">
                <i class="bi bi-sun-fill sun-icon"></i>
                <i class="bi bi-moon-stars-fill moon-icon"></i>
            </button>
            <button id="columnConfigBtn" class="text-gray-400 hover:text-white p-2 rounded-full hover:bg-gray-800 transition-all" title="Cấu hình hiển thị cột (Alt + C)">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M5 4a1 1 0 00-2 0v7.268a2 2 0 000 3.464V16a1 1 0 102 0v-1.268a2 2 0 000-3.464V4zM11 4a1 1 0 10-2 0v1.268a2 2 0 000 3.464V16a1 1 0 102 0V8.732a2 2 0 000-3.464V4zM16 3a1 1 0 011 1v7.268a2 2 0 010 3.464V16a1 1 0 11-2 0v-1.268a2 2 0 010-3.464V4a1 1 0 011-1z"></path></svg>
            </button>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="flex flex-col md:flex-row items-center gap-4 mb-4">
        <div class="relative">
            <button id="actionsBtn" class="btn-primary w-full md:w-auto px-6 py-2.5" title="Phím tắt: Alt + A">
                Hành động
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </button>
            <div id="actionsMenu" class="hidden absolute top-full left-0 mt-2 w-72 dropdown-menu rounded-xl shadow-2xl py-1 z-[9999]">
                <button id="exportBtn" class="w-full px-4 py-3 text-left hover:bg-gray-700/50 flex items-center gap-3 transition-colors" title="Phím tắt: Alt + E">
                    <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    <span class="flex-1 text-white font-medium">Xuất dữ liệu <span class="text-[10px] opacity-50 ml-1">(Alt+E)</span></span>
                </button>
                <div class="border-t border-gray-700/50 my-1"></div>
                <button id="copySelectedBtn" class="w-full px-4 py-3 text-left hover:bg-gray-700/50 flex items-center gap-3 transition-colors">
                    <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V7m-4 0h4v3m-4-7v4m-2 11h2a2 2 0 002-2v-5a2 2 0 00-2-2H5a2 2 0 00-2 2v5a2 2 0 002 2z" /></svg>
                    <span class="flex-1 text-white font-medium">Copy đã chọn <span class="text-[10px] opacity-50 ml-1">(Alt+K)</span></span>
                </button>
                <button id="deleteSelectedBtn" class="w-full px-4 py-3 text-left hover:bg-gray-700/50 flex items-center gap-3 transition-colors group">
                    <svg class="w-5 h-5 text-red-400 group-hover:text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    <span class="flex-1 text-white font-medium">Xóa đã chọn <span class="text-[10px] opacity-50 ml-1">(Alt+D)</span></span>
                </button>
            </div>
        </div>

        <div class="flex-1 relative flex gap-2 w-full">
            <div class="flex-1 relative">
                <svg class="w-5 h-5 absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                <input type="text" id="searchInput" placeholder="Tìm kiếm tên, email, sđt... (Alt+S hoặc /)" class="w-full pl-10 pr-4 py-2 dark-input rounded-xl" value="@ViewData["SearchTerm"]" />
            </div>
            <button id="toggleFilterBtn" class="btn-primary flex items-center gap-2 px-4 py-2" title="Phím tắt: Alt + F">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
                Bộ lọc <span class="text-[10px] opacity-50 font-mono">(Alt+F)</span>
            </button>
        </div>

        <button id="addBtn" class="btn-primary px-8 py-2.5 whitespace-nowrap" title="Phím tắt: Alt + N">
            <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Thêm mới <span class="text-[10px] opacity-50 ml-1 font-mono">(Alt+N)</span>
        </button>
    </div>

    <!-- Filter Panel -->
    <div id="filterPanel" class="hidden dark-card p-6 mb-6 border border-gray-700/50 animate-slide-down shadow-xl">
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-white font-bold flex items-center gap-2">
                <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
                Bộ lọc nâng cao
            </h3>
            <button id="resetFilterBtn" class="text-[10px] text-gray-400 hover:text-white uppercase font-bold px-3 py-1.5 border border-gray-700 rounded-lg transition-all">Đặt lại</button>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-x-6 gap-y-5">
            <div class="space-y-1.5">
                <label class="text-[11px] font-semibold text-gray-400 tracking-tight uppercase">Họ và tên</label>
                <input type="text" id="fFullName" class="dark-input w-full p-2 rounded-lg" placeholder="Nhập tên..." value="@ViewData["fFullName"]">
            </div>
            <div class="space-y-1.5">
                <label class="text-[11px] font-semibold text-gray-400 tracking-tight uppercase">Email</label>
                <input type="text" id="fEmail" class="dark-input w-full p-2 rounded-lg" placeholder="Nhập email..." value="@ViewData["fEmail"]">
            </div>
            <div class="space-y-1.5">
                <label class="text-[11px] font-semibold text-gray-400 tracking-tight uppercase">Số điện thoại</label>
                <input type="text" id="fPhone" class="dark-input w-full p-2 rounded-lg" placeholder="Nhập SĐT..." value="@ViewData["fPhone"]">
            </div>

            <div class="space-y-1.5">
                <label class="text-[11px] font-semibold text-gray-400 tracking-tight uppercase">Vai trò</label>
                <select id="fRoleId" class="dark-input w-full p-2 rounded-lg cursor-pointer">
                    <option value="">Tất cả vai trò</option>
                    @if (ViewBag.Roles != null) { foreach (var role in (IEnumerable<dynamic>)ViewBag.Roles) { 
                        bool isSelected = ViewData["fRoleId"]?.ToString() == role.Id.ToString();
                        if (isSelected) { <option value="@role.Id" selected>@role.Name</option> } else { <option value="@role.Id">@role.Name</option> }
                    } }
                </select>
            </div>
            <div class="space-y-1.5">
                <label class="text-[11px] font-semibold text-gray-400 tracking-tight uppercase">Trạng thái</label>
                <select id="fStatus" class="dark-input w-full p-2 rounded-lg cursor-pointer">
                    <option value="">Tất cả trạng thái</option>
                    <option value="1" selected="@(ViewData["fStatus"]?.ToString() == "1")">Hoạt động</option>
                    <option value="0" selected="@(ViewData["fStatus"]?.ToString() == "0")">Đang khóa</option>
                </select>
            </div>
            <div class="space-y-1.5">
                <label class="text-[11px] font-semibold text-gray-400 tracking-tight uppercase">Xác thực</label>
                <select id="fIsVerified" class="dark-input w-full p-2 rounded-lg cursor-pointer">
                    <option value="">Tất cả</option>
                    <option value="1" selected="@(ViewData["fIsVerified"]?.ToString() == "1")">Đã xác thực</option>
                    <option value="0" selected="@(ViewData["fIsVerified"]?.ToString() == "0")">Chưa xác thực</option>
                </select>
            </div>
        </div>
        
        <div class="flex justify-end mt-8 border-t border-gray-700/50 pt-6">
            <button id="applyFilterBtn" class="bg-blue-600 hover:bg-blue-500 text-white px-10 py-2 rounded-xl font-bold shadow-lg shadow-blue-900/20 transition-all flex items-center gap-2 text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                Áp dụng bộ lọc
            </button>
        </div>
    </div>

    <!-- Table -->
    <div class="dark-card overflow-x-auto shadow-2xl">
        <table class="w-full" id="userTable">
            <thead>
                <tr class="table-header border-b border-gray-700/50">
                    <th class="px-4 py-3 text-left sticky-col" data-col-id="checkbox"><input type="checkbox" id="selectAll" class="w-4 h-4 cursor-pointer accent-blue-600" /></th>
                    <th class="px-4 py-3 text-left sticky-col" data-col-id="stt">STT</th>
                    <th class="px-4 py-3 text-center" data-col-id="column-avatar">Ảnh</th>
                    <th class="px-4 py-3 text-left sortable-header cursor-pointer group" data-column="fullname" data-col-id="column-name">
                        <div class="flex items-center gap-1.5 theme-contrast">Họ và tên <span class="sort-icon opacity-0 group-hover:opacity-100 transition-opacity"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" /></svg></span></div>
                    </th>
                    <th class="px-4 py-3 text-left sortable-header cursor-pointer group" data-column="email" data-col-id="column-email">
                        <div class="flex items-center gap-1.5">Email <span class="sort-icon opacity-0 group-hover:opacity-100 transition-opacity"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" /></svg></span></div>
                    </th>
                    <th class="px-4 py-3 text-left" data-col-id="column-phone">SĐT</th>
                    <th class="px-4 py-3 text-left sortable-header cursor-pointer group" data-column="role" data-col-id="column-role">
                        <div class="flex items-center gap-1.5">Vai trò <span class="sort-icon opacity-0 group-hover:opacity-100 transition-opacity"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" /></svg></span></div>
                    </th>
                    <th class="px-4 py-3 text-left sortable-header cursor-pointer group" data-column="status" data-col-id="column-status">
                        <div class="flex items-center gap-1.5">Trạng thái <span class="sort-icon opacity-0 group-hover:opacity-100 transition-opacity"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" /></svg></span></div>
                    </th>
                    <th class="px-4 py-3 text-left sortable-header cursor-pointer group" data-column="verified" data-col-id="column-verified">
                        <div class="flex items-center gap-1.5">Xác thực <span class="sort-icon opacity-0 group-hover:opacity-100 transition-opacity"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" /></svg></span></div>
                    </th>
                    <th class="px-4 py-3 text-center sticky-col-right" data-col-id="actions">Thao tác</th>
                </tr>
            </thead>
            <tbody id="tableBody">
                @if (Model.Users != null && Model.Users.Any())
                {
                    int index = ((Model.CurrentPage - 1) * Model.PageSize) + 1;
                    foreach (var item in Model.Users)
                    {
                        <tr class="table-row text-sm border-b border-gray-800/30 hover:bg-gray-800/20 transition-colors" data-id="@item.Id"
                            data-copy-fullname="@item.FullName" data-copy-email="@item.Email" data-copy-phone="@item.Phone"
                            data-copy-role="@item.RoleId" data-copy-status="@item.Status" data-copy-verified="@item.IsVerified"
                            data-copy-avatar="@item.AvatarUrl">
                            <td class="px-4 py-3 sticky-col" data-col-id="checkbox"><input type="checkbox" class="userCheckbox w-4 h-4 cursor-pointer accent-blue-600" data-id="@item.Id" /></td>
                            <td class="px-4 py-3 sticky-col text-gray-500 font-mono" data-col-id="stt">@index</td>
                            <td class="px-4 py-3 text-center" data-col-id="column-avatar">
                                <img src="@(string.IsNullOrEmpty(item.AvatarUrl) ? "https://ui-avatars.com/api/?name=" + item.FullName + "&background=random" : item.AvatarUrl)" class="w-10 h-10 object-cover rounded-full mx-auto shadow-md border border-gray-700" />
                            </td>
                            <td class="px-4 py-3 font-semibold theme-contrast" data-col-id="column-name">@item.FullName</td>
                            <td class="px-4 py-3 text-blue-400 font-mono" data-col-id="column-email">@item.Email</td>
                            <td class="px-4 py-3 text-gray-400" data-col-id="column-phone">@item.Phone</td>
                            <td class="px-4 py-3" data-col-id="column-role">
                                <span class="px-2 py-1 rounded text-[10px] font-bold uppercase tracking-wider @(item.RoleId == 1 ? "bg-purple-900/30 text-purple-400 border border-purple-800/50" : "bg-blue-900/30 text-blue-400 border border-blue-800/50")">
                                    @(item.Role?.Name ?? "N/A")
                                </span>
                            </td>
                            <td class="px-4 py-3" data-col-id="column-status">
                                <span class="flex items-center gap-1.5 @(item.Status == 1 ? "text-green-400" : "text-red-400")">
                                    <span class="w-1.5 h-1.5 rounded-full @(item.Status == 1 ? "bg-green-400 animate-pulse" : "bg-red-400")"></span>
                                    @(item.Status == 1 ? "Hoạt động" : "Bị khóa")
                                </span>
                            </td>
                            <td class="px-4 py-3" data-col-id="column-verified">
                                @if(item.IsVerified == 1) {
                                    <span class="text-blue-400 flex items-center gap-1"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg> <span class="text-[11px] font-bold uppercase">OK</span></span>
                                } else {
                                    <span class="text-gray-600 flex items-center gap-1"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path></svg> <span class="text-[11px] font-bold uppercase">NO</span></span>
                                }
                            </td>
                            <td class="px-4 py-3 text-center sticky-col-right" data-col-id="actions">
                                <div class="flex items-center justify-center gap-1.5">
                                    <button type="button" class="viewBtn p-1.5 rounded-lg text-blue-400 hover:bg-blue-400/10 transition-all" title="Xem chi tiết" 
                                            data-id="@item.Id" data-fullname="@item.FullName" data-email="@item.Email" data-phone="@item.Phone" data-role="@item.Role?.Name" data-status="@item.Status" data-verified="@item.IsVerified" data-avatar="@item.AvatarUrl" data-created="@item.CreatedAt">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                                    </button>
                                    <button type="button" class="editBtn p-1.5 rounded-lg text-yellow-400 hover:bg-yellow-400/10 transition-all" title="Sửa">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                                    </button>
                                    <button type="button" class="deleteSingleBtn p-1.5 rounded-lg text-red-400 hover:bg-red-400/10 transition-all" title="Xóa" data-id="@item.Id">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        index++;
                    }
                }
                else
                {
                    <tr><td colspan="10" class="px-4 py-16 text-center text-gray-500 font-medium">Không tìm thấy tài khoản nào khớp với bộ lọc.</td></tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="pagination-container flex flex-col items-center gap-4 mt-8">
        @if (Model.TotalPages > 1)
        {
            <div class="flex items-center justify-center gap-2">
                <a href="@Url.Action("Index", new { page = 1, searchTerm = ViewData["SearchTerm"], fFullName = ViewData["fFullName"], fEmail = ViewData["fEmail"], fPhone = ViewData["fPhone"], fRoleId = ViewData["fRoleId"], fStatus = ViewData["fStatus"], fIsVerified = ViewData["fIsVerified"] })" 
                   class="w-10 h-10 rounded-lg bg-gray-800 flex items-center justify-center text-blue-400 transition-all @(Model.CurrentPage == 1 ? "pointer-events-none opacity-30" : "hover:bg-gray-700 hover:text-white")">
                   <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M15.707 15.707a1 1 0 01-1.414 0l-5-5a1 1 0 010-1.414l5-5a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 010 1.414zm-6 0a1 1 0 01-1.414 0l-5-5a1 1 0 010-1.414l5-5a1 1 0 011.414 1.414L5.414 10l4.293 4.293a1 1 0 010 1.414z" /></svg>
                </a>
                
                @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                {
                    <a href="@Url.Action("Index", new { page = i, searchTerm = ViewData["SearchTerm"], fFullName = ViewData["fFullName"], fEmail = ViewData["fEmail"], fPhone = ViewData["fPhone"], fRoleId = ViewData["fRoleId"], fStatus = ViewData["fStatus"], fIsVerified = ViewData["fIsVerified"] })" 
                       class="w-10 h-10 rounded-lg flex items-center justify-center font-bold transition-all @(i == Model.CurrentPage ? "bg-blue-600 text-white shadow-lg shadow-blue-900/40" : "bg-gray-800 text-gray-400 hover:bg-gray-700 hover:text-white")">
                        @i
                    </a>
                }

                <a href="@Url.Action("Index", new { page = Model.TotalPages, searchTerm = ViewData["SearchTerm"], fFullName = ViewData["fFullName"], fEmail = ViewData["fEmail"], fPhone = ViewData["fPhone"], fRoleId = ViewData["fRoleId"], fStatus = ViewData["fStatus"], fIsVerified = ViewData["fIsVerified"] })" 
                   class="w-10 h-10 rounded-lg bg-gray-800 flex items-center justify-center text-blue-400 transition-all @(Model.CurrentPage == Model.TotalPages ? "pointer-events-none opacity-30" : "hover:bg-gray-700 hover:text-white")">
                   <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M4.293 4.293a1 1 0 011.414 0l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414zm6 0a1 1 0 011.414 0l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414-1.414L14.586 10l-4.293-4.293a1 1 0 010-1.414z" /></svg>
                </a>
                
                <div class="flex items-center gap-2 ml-4 px-3 py-1.5 bg-gray-800/50 rounded-xl border border-gray-700/50">
                    <span class="text-[10px] text-gray-500 uppercase font-bold">Đi tới</span>
                    <input type="number" id="goToPageInput" value="@Model.CurrentPage" min="1" max="@Model.TotalPages" 
                           class="w-12 bg-transparent text-white text-center text-sm font-bold focus:outline-none" 
                           onchange="window.location.href='@Url.Action("Index")?searchTerm=@ViewData["SearchTerm"]&fFullName=@ViewData["fFullName"]&fEmail=@ViewData["fEmail"]&fPhone=@ViewData["fPhone"]&fRoleId=@ViewData["fRoleId"]&fStatus=@ViewData["fStatus"]&fIsVerified=@ViewData["fIsVerified"]&page=' + this.value" />
                    <span class="text-[10px] text-gray-500">/ @Model.TotalPages</span>
                </div>
            </div>
        }
    </div>
</div>

