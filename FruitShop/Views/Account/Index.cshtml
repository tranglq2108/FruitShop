@model FruitShop.Models.User
@{
    ViewData["Title"] = "Tài khoản của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row g-4">
        <!-- Sidebar -->
        <div class="col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <div class="text-center mb-4">
                    <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 80px; height: 80px; font-size: 2rem;">
                        @(Model.FullName?.Substring(0, 1) ?? "U")
                    </div>
                    <h5 class="fw-bold mb-0">@Model.FullName</h5>
                    <p class="text-muted small">@Model.Email</p>
                </div>
                <div class="list-group list-group-flush">
                    <a asp-action="Index" class="list-group-item list-group-item-action border-0 py-3 active rounded-3 mb-2">
                        <i class="fas fa-user me-2"></i>Thông tin cá nhân
                    </a>
                    <a asp-action="EditProfile" class="list-group-item list-group-item-action border-0 py-3 rounded-3 mb-2">
                        <i class="fas fa-user-edit me-2"></i>Chỉnh sửa hồ sơ
                    </a>
                    <a asp-action="ChangePassword" class="list-group-item list-group-item-action border-0 py-3 rounded-3 mb-2">
                        <i class="fas fa-key me-2"></i>Đổi mật khẩu
                    </a>
                    <a asp-controller="Orders" asp-action="Index" class="list-group-item list-group-item-action border-0 py-3 rounded-3">
                        <i class="fas fa-shopping-bag me-2"></i>Đơn hàng của tôi
                    </a>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-lg-9">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <h4 class="fw-bold mb-4">Thông tin cá nhân</h4>
                
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="text-muted small mb-1">Họ và Tên</label>
                        <p class="fw-bold fs-5">@Model.FullName</p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small mb-1">Email</label>
                        <p class="fw-bold fs-5">@Model.Email</p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small mb-1">Số điện thoại</label>
                        <p class="fw-bold fs-5">@(Model.Phone ?? "Chưa cập nhật")</p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small mb-1">Ngày tham gia</label>
                        <p class="fw-bold fs-5">@Model.CreatedAt?.ToString("dd/MM/yyyy")</p>
                    </div>
                </div>

                <div class="mt-4 pt-4 border-top">
                    <a asp-action="EditProfile" class="btn btn-success rounded-pill px-4 fw-bold">Chỉnh sửa thông tin</a>
                </div>
            </div>
        </div>
    </div>
</div>
