@{
    ViewData["Title"] = "Đổi mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row g-4">
        <!-- Sidebar -->
        <div class="col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <div class="text-center mb-4">
                    <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 80px; height: 80px; font-size: 2rem;">
                        @(Context.Session.GetString("UserName")?.Substring(0, 1) ?? "U")
                    </div>
                    <h5 class="fw-bold mb-0">@Context.Session.GetString("UserName")</h5>
                    <p class="text-muted small">@Context.Session.GetString("UserEmail")</p>
                </div>
                <div class="list-group list-group-flush">
                    <a asp-action="Index" class="list-group-item list-group-item-action border-0 py-3 rounded-3 mb-2">
                        <i class="fas fa-user me-2"></i>Thông tin cá nhân
                    </a>
                    <a asp-action="EditProfile" class="list-group-item list-group-item-action border-0 py-3 rounded-3 mb-2">
                        <i class="fas fa-user-edit me-2"></i>Chỉnh sửa hồ sơ
                    </a>
                    <a asp-action="ChangePassword" class="list-group-item list-group-item-action border-0 py-3 active rounded-3 mb-2">
                        <i class="fas fa-key me-2"></i>Đổi mật khẩu
                    </a>
                    <a asp-controller="Orders" asp-action="Index" class="list-group-item list-group-item-action border-0 py-3 rounded-3">
                        <i class="fas fa-shopping-bag me-2"></i>Đơn hàng của tôi
                    </a>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-lg-9">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <h4 class="fw-bold mb-4">Đổi mật khẩu</h4>
                
                <form asp-action="ChangePassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-12">
                            <label class="form-label fw-bold small text-muted">Mật khẩu hiện tại</label>
                            <input type="password" name="currentPassword" class="form-control rounded-3" placeholder="Nhập mật khẩu hiện tại" required>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-bold small text-muted">Mật khẩu mới</label>
                            <input type="password" name="newPassword" class="form-control rounded-3" placeholder="Nhập mật khẩu mới" required>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-bold small text-muted">Xác nhận mật khẩu mới</label>
                            <input type="password" name="confirmPassword" class="form-control rounded-3" placeholder="Nhập lại mật khẩu mới" required>
                        </div>
                    </div>

                    <div class="mt-4 pt-4 border-top d-flex gap-2">
                        <button type="submit" class="btn btn-success rounded-pill px-4 fw-bold">Cập nhật mật khẩu</button>
                        <a asp-action="Index" class="btn btn-light rounded-pill px-4 fw-bold">Hủy bỏ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
