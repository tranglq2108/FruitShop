@model List<FruitShop.Models.CartItem>

@{
    ViewData["Title"] = "Thanh toán";
}

<div class="container py-5">
     <div class="row">
          <!-- Checkout Form -->
          <div class="col-lg-8">
               <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                    <h3 class="fw-bold mb-4"><i class="fas fa-user-check text-success me-2"></i>Thông tin giao hàng</h3>
                    
                    <form id="checkoutForm">
                         <div class="row">
                         <div class="col-md-6 mb-3">
                              <label class="form-label fw-bold">Tên người nhận <span class="text-danger">*</span></label>
                              <input type="text" class="form-control rounded-3" id="receiverName" name="receiverName" placeholder="Nhập tên đầy đủ" required>
                         </div>
                         <div class="col-md-6 mb-3">
                              <label class="form-label fw-bold">Số điện thoại <span class="text-danger">*</span></label>
                              <input type="tel" class="form-control rounded-3" id="receiverPhone" name="receiverPhone" placeholder="Nhập số điện thoại" required>
                         </div>
                         </div>

                         <div class="mb-3">
                              <label class="form-label fw-bold">Địa chỉ giao hàng <span class="text-danger">*</span></label>
                              <input type="text" class="form-control rounded-3" id="receiverAddress" name="receiverAddress" placeholder="Nhập địa chỉ đầy đủ" required>
                         </div>

                         <div class="mb-4">
                              <label class="form-label fw-bold">Ghi chú đơn hàng</label>
                              <textarea class="form-control rounded-3" id="note" name="note" rows="3" placeholder="Ghi chú khi giao hàng (tùy chọn)"></textarea>
                         </div>

                         <div class="mb-4">
                              <label class="form-label fw-bold">Mã giảm giá (nếu có)</label>
                              <div class="input-group">
                                   <input type="text" class="form-control rounded-3" id="couponCode" name="couponCode" placeholder="Nhập mã giảm giá" style="border-radius: 0.75rem 0 0 0.75rem !important;">
                                   <button type="button" class="btn btn-outline-success rounded-3" onclick="applyCoupon()" style="border-radius: 0 0.75rem 0.75rem 0 !important;">
                                        <i class="fas fa-tag me-1"></i>Áp dụng
                                   </button>
                              </div>
                              <small class="text-muted d-block mt-2">Ví dụ: GIAM50K, FREESHIP, WELCOME, SUMMER24</small>
                              <div id="couponMessage" class="mt-2"></div>
                         </div>

                         <h3 class="fw-bold mb-4"><i class="fas fa-credit-card text-success me-2"></i>Phương thức thanh toán</h3>

                         <div class="mb-4">
                         <div class="form-check p-3 border rounded-3 mb-3" style="background-color: #f9fff5;">
                              <div class="d-flex align-items-center gap-3">
                                   <input class="form-check-input" type="radio" name="paymentMethod" id="payment_cod" value="COD" checked style="margin-top: 0;">
                                   <div>
                                        <label class="form-check-label fw-bold d-block" for="payment_cod">
                                             <i class="fas fa-money-bill text-success me-2"></i>Thanh toán khi nhận hàng (COD)
                                        </label>
                                        <small class="d-block text-muted mt-2">Bạn sẽ thanh toán khi nhân viên giao hàng đến tại địa chỉ của bạn</small>
                                   </div>
                              </div>
                         </div>

                         <div class="form-check p-3 border rounded-3 mb-3" style="background-color: #f9fff5;">
                              <div class="d-flex align-items-center gap-3">
                                   <input class="form-check-input" type="radio" name="paymentMethod" id="payment_bank" value="BANK_TRANSFER" style="margin-top: 0;">
                                   <div>
                                        <label class="form-check-label fw-bold d-block" for="payment_bank">
                                             <i class="fas fa-university text-success me-2"></i>Chuyển khoản ngân hàng
                                        </label>
                                        <small class="d-block text-muted mt-2">Chuyển tiền trực tiếp vào tài khoản ngân hàng của chúng tôi</small>
                                   </div>
                              </div>
                         </div>

                         <div class="form-check p-3 border rounded-3" style="background-color: #f9fff5;">
                              <div class="d-flex align-items-center gap-3">
                                   <input class="form-check-input" type="radio" name="paymentMethod" id="payment_wallet" value="WALLET" style="margin-top: 0;">
                                   <div>
                                        <label class="form-check-label fw-bold d-block" for="payment_wallet">
                                             <i class="fas fa-wallet text-success me-2"></i>Ví điện tử (E-Wallet)
                                        </label>
                                        <small class="d-block text-muted mt-2">Thanh toán qua VnPay, Momo, ZaloPay hoặc các ví điện tử khác</small>
                                   </div>
                              </div>
                         </div>
                         </div>

                         <button type="submit" class="btn btn-success w-100 rounded-pill fw-bold py-3">
                              <i class="fas fa-check-circle me-2"></i>Xác nhận thanh toán
                         </button>
                         <input type="hidden" id="selectedProductsInput" name="selectedProducts">
                    </form>
               </div>
          </div>

          <!-- Order Summary -->
          <div class="col-lg-4">
               <div class="card border-0 shadow-sm rounded-4 p-4 sticky-top" style="top: 20px;">
                    <h5 class="fw-bold mb-4"><i class="fas fa-list text-success me-2"></i>Đơn hàng</h5>

                    @{
                         decimal subtotal = 0;
                         if (Model != null && Model.Count > 0)
                         {
                         subtotal = Model.Sum(x => (x.Product?.FinalPrice ?? 0) * (x.Quantity ?? 1));
                         }
                    }

                    @if (Model != null && Model.Count > 0)
                    {
                         <div class="mb-4" style="max-height: 300px; overflow-y: auto;">
                         @foreach (var item in Model)
                         {
                              var price = item.Product?.FinalPrice ?? 0;
                              var total = price * (item.Quantity ?? 1);

                              <div class="d-flex justify-content-between align-items-start mb-3 pb-3 border-bottom" data-product-item data-product-id="@item.ProductId">
                                   <div class="d-flex align-items-center gap-3">
                                        <div class="bg-light rounded p-1" style="width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; overflow: hidden; flex-shrink: 0;">
                                             @{
                                                  var productImageUrl = item.Product?.ProductImages?.FirstOrDefault(pi => pi.IsMain == 1)?.ImageUrl 
                                                                      ?? item.Product?.ProductImages?.FirstOrDefault()?.ImageUrl 
                                                                      ?? "https://via.placeholder.com/50x50?text=" + item.Product?.Name;
                                             }
                                             <img src="@productImageUrl" alt="@item.Product?.Name" style="width: 100%; height: 100%; object-fit: contain;">
                                        </div>
                                        <div style="max-width: 180px;">
                                             <p class="mb-0 fw-bold small text-truncate">@item.Product?.Name</p>
                                             <small class="text-muted">SL: <span data-item-quantity>@item.Quantity</span> x @price.ToString("N0")đ</small>
                                        </div>
                                   </div>
                                   <div class="text-end">
                                        <p class="mb-0 fw-bold text-success small" data-item-total>@total.ToString("N0")đ</p>
                                        <span class="d-none" data-item-price>@price.ToString("F0")</span>
                                   </div>
                              </div>
                         }
                         </div>

                         <hr>

                         <div class="d-flex justify-content-between mb-2">
                              <span class="text-muted">Tạm tính:</span>
                              <span class="fw-bold" data-order-subtotal>@subtotal.ToString("N0") đ</span>
                         </div>

                         <div class="d-flex justify-content-between mb-2">
                              <span class="text-muted">Phí vận chuyển:</span>
                              <span class="fw-bold" id="shippingFee">30,000 đ</span>
                         </div>

                         <div class="d-flex justify-content-between mb-2">
                              <span class="text-muted">Giảm giá:</span>
                              <span class="fw-bold text-danger" id="discountAmount">0 đ</span>
                         </div>

                         <hr>

                         <div class="d-flex justify-content-between">
                              <span class="fw-bold">Tổng cộng:</span>
                              <span class="fw-bold text-success fs-5" data-order-total id="finalTotal">@((subtotal + 30000).ToString("N0")) đ</span>
                         </div>
                    }
                    else
                    {
                         <p class="text-muted text-center">Giỏ hàng trống</p>
                    }
               </div>
          </div>
     </div>
</div>

<script>
     // Get selected products from sessionStorage
     let selectedProducts = JSON.parse(sessionStorage.getItem('selectedProducts') || '[]');
     
     // If no selected products, redirect back to cart
     if (selectedProducts.length === 0) {
          alert('Vui lòng chọn sản phẩm để thanh toán');
          window.location.href = '/Cart/Index';
     }

     // Store selected products in hidden input
     document.getElementById('selectedProductsInput').value = JSON.stringify(selectedProducts);

     // Coupon data
     let appliedCoupon = null;
     const SHIPPING_FEE = 30000;

     function getSubtotal() {
          let subtotal = 0;
          document.querySelectorAll('[data-product-item]').forEach(item => {
               const quantityText = item.querySelector('[data-item-quantity]')?.textContent;
               const priceText = item.querySelector('[data-item-price]')?.textContent;
               
               if (priceText && quantityText) {
                    // Use parseFloat and handle potential comma as decimal separator
                    const price = parseFloat(priceText.replace(',', '.'));
                    const quantity = parseInt(quantityText.replace(/[^0-9]/g, ''));
                    if (!isNaN(price) && !isNaN(quantity)) {
                         subtotal += price * quantity;
                    }
               }
          });
          return subtotal;
     }

     function calculateDiscount(subtotal) {
          if (!appliedCoupon) return 0;
          
          const coupon = appliedCoupon;
          
          // Check minimum order value
          if (subtotal < coupon.minOrderValue) {
               return 0;
          }
          
          let discount = 0;
          if (coupon.discountType === 'fixed') {
               discount = coupon.discountValue;
          } else if (coupon.discountType === 'percent') {
               discount = Math.floor(subtotal * coupon.discountValue / 100);
               // Cap to maxDiscount if specified
               if (coupon.maxDiscount && discount > coupon.maxDiscount) {
                    discount = coupon.maxDiscount;
               }
          }
          
          return discount;
     }

     function updateOrderTotal() {
          const subtotal = getSubtotal();
          const discount = calculateDiscount(subtotal);
          const total = subtotal + SHIPPING_FEE - discount;
          
          // Update display
          document.getElementById('discountAmount').textContent = discount.toLocaleString('vi-VN') + ' đ';
          document.getElementById('finalTotal').textContent = total.toLocaleString('vi-VN') + ' đ';
     }

     function applyCoupon() {
          const couponCode = document.getElementById('couponCode').value.trim().toUpperCase();
          const messageDiv = document.getElementById('couponMessage');
          
          if (!couponCode) {
               messageDiv.innerHTML = '<span class="text-warning"><i class="fas fa-exclamation-circle me-1"></i>Vui lòng nhập mã giảm giá</span>';
               appliedCoupon = null;
               updateOrderTotal();
               return;
          }

          // Call backend to validate coupon
          fetch('/Cart/ValidateCoupon', {
               method: 'POST',
               headers: {
                    'Content-Type': 'application/json',
               },
               body: JSON.stringify({
                    couponCode: couponCode,
                    subtotal: getSubtotal()
               })
          })
          .then(response => response.json())
          .then(data => {
               if (data.success) {
                    appliedCoupon = data.coupon;
                    messageDiv.innerHTML = '<span class="text-success"><i class="fas fa-check-circle me-1"></i>Áp dụng thành công! Giảm ' + data.coupon.discountDisplay + '</span>';
                    document.getElementById('discountAmount').textContent = (data.discountAmount || 0).toLocaleString('vi-VN') + ' đ';
                    document.getElementById('finalTotal').textContent = (data.finalTotal || (getSubtotal() + SHIPPING_FEE - (data.discountAmount || 0))).toLocaleString('vi-VN') + ' đ';
               } else {
                    messageDiv.innerHTML = '<span class="text-danger"><i class="fas fa-times-circle me-1"></i>' + data.message + '</span>';
                    appliedCoupon = null;
                    updateOrderTotal();
               }
          })
          .catch(error => {
               console.error('Error:', error);
               messageDiv.innerHTML = '<span class="text-danger"><i class="fas fa-times-circle me-1"></i>Lỗi khi kiểm tra mã</span>';
               appliedCoupon = null;
               updateOrderTotal();
          });
     }

     document.getElementById('checkoutForm').addEventListener('submit', function(e) {
          e.preventDefault();

          const receiverName = document.getElementById('receiverName').value;
          const receiverPhone = document.getElementById('receiverPhone').value;
          const receiverAddress = document.getElementById('receiverAddress').value;
          const note = document.getElementById('note').value;
          const paymentMethod = document.querySelector('input[name="paymentMethod"]:checked').value;
          const couponCode = appliedCoupon ? appliedCoupon.code : null;

          // Validation
          if (!receiverName || !receiverPhone || !receiverAddress) {
               alert('Vui lòng điền đầy đủ thông tin giao hàng');
               return;
          }

          // Phone validation (Vietnamese)
          const phoneRegex = /^(0[1-9][0-9]{8})$/;
          if (!phoneRegex.test(receiverPhone)) {
               alert('Số điện thoại không hợp lệ (phải là 10 chữ số bắt đầu bằng 0)');
               return;
          }

          // Submit order with selected products and coupon
          fetch('/Cart/CreateOrder', {
               method: 'POST',
               headers: {
                    'Content-Type': 'application/json',
               },
               body: JSON.stringify({
                    receiverName: receiverName,
                    receiverPhone: receiverPhone,
                    receiverAddress: receiverAddress,
                    note: note,
                    paymentMethod: paymentMethod,
                    selectedProducts: selectedProducts,
                    couponCode: couponCode
               })
          })
          .then(response => response.json())
          .then(data => {
               if (data.success) {
                    sessionStorage.removeItem('selectedProducts');
                    window.location.href = data.redirectUrl || '/Cart/PaymentSuccess?orderId=' + data.orderId;
               } else {
                    alert('Lỗi: ' + (data.message || 'Không thể tạo đơn hàng'));
               }
          })
          .catch(error => {
               console.error('Error:', error);
               alert('Có lỗi xảy ra khi tạo đơn hàng');
          });
     });

     // Initialize
     updateOrderTotal();
     
     // Auto-load coupon from cart page if exist
     const savedCouponCode = sessionStorage.getItem('appliedCoupon');
     if (savedCouponCode) {
          document.getElementById('couponCode').value = savedCouponCode;
          // Auto apply the coupon
          setTimeout(() => {
               applyCoupon();
               sessionStorage.removeItem('appliedCoupon');
          }, 100);
     }
</script>

<style>
     .form-control, .form-check {
          border-color: #dee2e6;
     }

     .form-control:focus {
          border-color: #198754;
          box-shadow: 0 0 0 0.2rem rgba(25, 135, 84, 0.15);
     }

     .form-check-input {
          width: 1.25em;
          height: 1.25em;
          margin-top: 0.3em;
          cursor: pointer;
          flex-shrink: 0;
          margin-left: 0 !important;
     }

     .form-check-input:checked {
          background-color: #198754;
          border-color: #198754;
     }

     .sticky-top {
          top: 100px;
     }
</style>
