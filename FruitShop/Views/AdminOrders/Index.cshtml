<div id="toastContainer" class="fixed top-4 right-4 z-[100] space-y-2"></div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            let currentOrderId = null;
            const urlParams = new URLSearchParams(window.location.search);

            // --- HELPER FUNCTIONS ---
            function showToast(msg, type = 'success') {
                const container = document.getElementById('toastContainer');
                if (!container) return;
                const t = document.createElement('div');
                t.className = `dark-card px-6 py-3.5 rounded-xl border-l-4 ${type === 'success' ? 'border-blue-500' : 'border-red-500'} shadow-2xl text-white animate-fade-in mb-2 flex items-center gap-3`;
                const icon = type === 'success' ? '<svg class="w-5 h-5 text-blue-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>' : '<svg class="w-5 h-5 text-red-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>';
                t.innerHTML = `${icon} <span class="font-medium text-sm">${msg}</span>`;
                container.appendChild(t);
                setTimeout(() => {
                    t.classList.add('opacity-0');
                    setTimeout(() => t.remove(), 500);
                }, 3000);
            }

            const formatMoney = (v) => v ? parseInt(v).toLocaleString('vi-VN') + ' đ' : '0 đ';

            // --- SELECTION LOGIC ---
            const updateSelectionUI = () => {
                const checkedCount = document.querySelectorAll('.orderCheckbox:checked').length;
                const selectAllEl = document.getElementById('selectAll');
                const checkboxes = document.querySelectorAll('.orderCheckbox');
                
                if (selectAllEl) {
                    selectAllEl.checked = (checkboxes.length > 0 && checkedCount === checkboxes.length);
                }
            };

            document.getElementById('selectAll').onchange = function () {
                document.querySelectorAll('.orderCheckbox').forEach(cb => cb.checked = this.checked);
                updateSelectionUI();
            };

            // --- SEARCH & FILTER AJAX ---
            function performSearch(page = 1) {
                const term = document.getElementById('searchInput').value;
                urlParams.set('searchTerm', term);
                urlParams.set('page', page);

                const status = document.getElementById('fStatus').value;
                if(status) urlParams.set('status', status); else urlParams.delete('status');

                const startDate = document.getElementById('fStartDate').value;
                if(startDate) urlParams.set('fStartDate', startDate); else urlParams.delete('fStartDate');

                const endDate = document.getElementById('fEndDate').value;
                if(endDate) urlParams.set('fEndDate', endDate); else urlParams.delete('fEndDate');

                const minP = document.getElementById('fMinPrice').value;
                if(minP) urlParams.set('fMinPrice', minP); else urlParams.delete('fMinPrice');

                const maxP = document.getElementById('fMaxPrice').value;
                if(maxP) urlParams.set('fMaxPrice', maxP); else urlParams.delete('fMaxPrice');

                const newUrl = `${window.location.pathname}?${urlParams.toString()}`;
                window.history.pushState({ path: newUrl }, '', newUrl);

                fetch(newUrl)
                    .then(r => r.text())
                    .then(html => {
                        const doc = new DOMParser().parseFromString(html, 'text/html');
                        const newStats = doc.getElementById('ordersSummary');
                        const currentStats = document.getElementById('ordersSummary');
                        if (newStats && currentStats) currentStats.innerHTML = newStats.innerHTML;
                        const tableBody = document.getElementById('tableBody');
                        tableBody.innerHTML = doc.getElementById('tableBody').innerHTML;
                        const newPag = doc.querySelector('.pagination-container');
                        const pagCont = document.querySelector('.pagination-container');
                        if (newPag && pagCont) pagCont.innerHTML = newPag.innerHTML;
                        attachRowEvents();
                        applyColumnConfig();
                        updateSelectionUI(); 
                    });
            }

            const debounce = (fn, d) => { let t; return (...a) => { clearTimeout(t); t = setTimeout(() => fn(...a), d); }; };
            document.getElementById('searchInput').oninput = debounce(() => performSearch(1), 300);

            document.getElementById('applyFilterBtn').onclick = () => {
                document.getElementById('filterPanel').classList.add('hidden');
                performSearch(1);
            };
            
            document.getElementById('resetFilterBtn').onclick = () => {
                document.querySelectorAll('#filterPanel input, #filterPanel select').forEach(i => i.value = '');
                performSearch(1);
            };

            // --- EXPORT LOGIC ---
            document.getElementById('exportBtn').onclick = () => {
                document.getElementById('exportSelectedCount').innerText = document.querySelectorAll('.orderCheckbox:checked').length;
                document.getElementById('exportModal').classList.remove('hidden');
            };

            document.getElementById('doExportBtn').onclick = function () {
                const scope = document.querySelector('input[name="exportScope"]:checked').value;
                const params = new URLSearchParams(urlParams);
                if (scope === 'selected') {
                    const ids = Array.from(document.querySelectorAll('.orderCheckbox:checked')).map(cb => cb.dataset.id).join(',');
                    if (!ids) return showToast("Vui lòng chọn đơn hàng!", "error");
                    params.set('ids', ids);
                }
                window.location.href = `/AdminOrders/ExportExcel?${params.toString()}`;
                document.getElementById('exportModal').classList.add('hidden');
            };

            // --- DETAILS ---
            function attachRowEvents() {
                document.querySelectorAll('.orderCheckbox').forEach(cb => {
                    cb.onchange = updateSelectionUI;
                });
                document.querySelectorAll('.viewBtn').forEach(btn => {
                    btn.onclick = function () {
                        const id = this.dataset.id;
                        currentOrderId = id;
                        fetch(`/AdminOrders/GetDetails?id=${id}`)
                            .then(r => r.json())
                            .then(res => {
                                if (res.success) {
                                    const d = res.data;
                                    document.getElementById('detOrderId').innerText = `#${d.id.toString().padStart(5, '0')}`;
                                    document.getElementById('detOrderTime').innerText = `Ngày đặt: ${d.createdAt}`;
                                    document.getElementById('detReceiver').innerText = d.receiverName;
                                    document.getElementById('detPhone').innerText = d.receiverPhone;
                                    document.getElementById('detAddress').innerText = d.receiverAddress;
                                    document.getElementById('detNote').innerText = d.note || 'Không có ghi chú';
                                    document.getElementById('detDiscount').innerText = `-${formatMoney(d.discountAmount)}`;
                                    document.getElementById('detTotal').innerText = formatMoney(d.totalAmount);
                                    
                                    // Render Status Badge
                                    let statusClass = "", statusText = "";
                                    switch(d.status) {
                                        case 1: statusClass = "bg-blue-900/30 text-blue-400"; statusText = "Chờ xác nhận"; break;
                                        case 2: statusClass = "bg-yellow-900/30 text-yellow-400"; statusText = "Đang giao hàng"; break;
                                        case 3: statusClass = "bg-green-900/30 text-green-400"; statusText = "Đã hoàn thành"; break;
                                        case 4: statusClass = "bg-red-900/30 text-red-400"; statusText = "Đã hủy đơn"; break;
                                        default: statusClass = "bg-gray-900/30 text-gray-400"; statusText = "Không xác định";
                                    }
                                    document.getElementById('detStatusBadge').innerHTML = `<span class="px-3 py-1.5 rounded-xl text-xs font-bold ${statusClass}">${statusText}</span>`;

                                    const list = document.getElementById('detItemsList');
                                    list.innerHTML = '';
                                    d.items.forEach(item => {
                                        list.innerHTML += `<tr class="border-b border-gray-700/30 hover:bg-gray-800/10 transition-colors">
                                            <td class="px-4 py-3 text-gray-200">${item.productName}</td>
                                            <td class="px-4 py-3 text-center text-gray-400 font-bold">${item.quantity}</td>
                                            <td class="px-4 py-3 text-right text-gray-500 font-mono">${formatMoney(item.unitPrice)}</td>
                                            <td class="px-4 py-3 text-right font-black text-blue-400 font-mono">${formatMoney(item.total)}</td>
                                        </tr>`;
                                    });
                                    document.getElementById('detailsModal').classList.remove('hidden');
                                }
                            });
                    };
                });
            }

            // --- COLUMN CONFIG ---
            const defaultCols = [
                { id: 'checkbox', name: 'Chọn', visible: true }, { id: 'stt', name: 'STT', visible: true }, 
                { id: 'column-id', name: 'Mã đơn', visible: true }, { id: 'column-customer', name: 'Khách hàng', visible: true }, 
                { id: 'column-phone', name: 'Số điện thoại', visible: true }, { id: 'column-date', name: 'Ngày đặt', visible: true },
                { id: 'column-amount', name: 'Tổng tiền', visible: true }, { id: 'column-items', name: 'Số SP', visible: true },
                { id: 'column-status', name: 'Trạng thái', visible: true }, { id: 'actions', name: 'Thao tác', visible: true }
            ];
            let colCfg = JSON.parse(localStorage.getItem('orderColumnConfig')) || defaultCols;

            const applyColumnConfig = () => {
                const table = document.getElementById('orderTable');
                if (!table) return;
                const rows = table.querySelectorAll('tr');
                rows.forEach(row => {
                    colCfg.forEach(c => {
                        const cell = row.querySelector(`[data-col-id="${c.id}"]`);
                        if (cell) { cell.style.display = c.visible ? '' : 'none'; row.appendChild(cell); }
                    });
                });
            };

            let sortableInstance = null;
            document.getElementById('columnConfigBtn').onclick = () => {
                const list = document.getElementById('columnList');
                if (!list) return; list.innerHTML = '';
                colCfg.forEach((c) => {
                    const d = document.createElement('div');
                    d.className = "flex items-center gap-3 p-3 bg-gray-800/50 rounded-xl hover:bg-gray-800 transition-colors border border-gray-700/30 cursor-move group";
                    d.dataset.id = c.id;
                    d.innerHTML = `<div class="text-gray-500 group-hover:text-gray-300"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M7 2a2 2 0 11.001 3.999A2 2 0 017 2zm0 6a2 2 0 11.001 3.999A2 2 0 017 8zm0 6a2 2 0 11.001 3.999A2 2 0 017 14zm6-12a2 2 0 11.001 3.999A2 2 0 0113 2zm0 6a2 2 0 11.001 3.999A2 2 0 0113 8zm0 6a2 2 0 11.001 3.999A2 2 0 0113 14z" /></svg></div><span class="flex-1 text-sm font-medium theme-contrast">${c.name}</span><input type="checkbox" ${c.visible ? 'checked' : ''} class="col-visibility w-5 h-5 rounded accent-blue-600 cursor-pointer">`;
                    list.appendChild(d);
                });
                if (sortableInstance) sortableInstance.destroy();
                sortableInstance = new Sortable(list, { animation: 150, ghostClass: 'bg-blue-600/10' });
                document.getElementById('columnConfigModal').classList.remove('hidden');
            };

            document.getElementById('saveColumnsBtn').onclick = () => {
                const listItems = document.querySelectorAll('#columnList > div');
                const newCfg = [];
                listItems.forEach(item => {
                    const id = item.dataset.id;
                    const visible = item.querySelector('.col-visibility').checked;
                    const originalCol = defaultCols.find(dc => dc.id === id) || { name: 'N/A' };
                    newCfg.push({ id, name: originalCol.name, visible });
                });
                colCfg = newCfg; localStorage.setItem('orderColumnConfig', JSON.stringify(colCfg));
                applyColumnConfig(); document.getElementById('columnConfigModal').classList.add('hidden');
                showToast("Đã lưu cấu hình cột");
            };

            document.getElementById('resetColumnsBtn').onclick = () => {
                colCfg = JSON.parse(JSON.stringify(defaultCols)); localStorage.removeItem('orderColumnConfig');
                applyColumnConfig(); document.getElementById('columnConfigModal').classList.add('hidden');
                showToast("Đã khôi phục cài đặt gốc");
            };

            // --- UI EVENTS ---
            document.querySelectorAll('.close-modal').forEach(b => {
                b.onclick = () => b.closest('.fixed').classList.add('hidden');
            });
            document.getElementById('toggleFilterBtn').onclick = () => {
                document.getElementById('filterPanel').classList.toggle('hidden');
            };
            const pagContainer = document.querySelector('.pagination-container');
            if (pagContainer) {
                pagContainer.onclick = (e) => {
                    const btn = e.target.closest('button[data-page]');
                    if (btn) performSearch(btn.dataset.page);
                };
                pagContainer.onchange = (e) => {
                    if (e.target.id === 'goToPageInput') {
                        let v = parseInt(e.target.value);
                        const max = parseInt(e.target.max);
                        if (isNaN(v) || v < 1) v = 1; if (v > max) v = max;
                        e.target.value = v; performSearch(v);
                    }
                };
            }
            // --- KEYBOARD SHORTCUTS ---
            document.addEventListener('keydown', function (e) {
                const inInput = ['INPUT', 'TEXTAREA', 'SELECT'].includes(document.activeElement.tagName);

                if (e.key === 'Escape') {
                    const openModals = document.querySelectorAll('.fixed:not(.hidden)');
                    if (openModals.length > 0) {
                        openModals.forEach(m => m.classList.add('hidden'));
                    } else if (inInput) {
                        document.activeElement.blur();
                    }
                }

                if (e.altKey) {
                    const map = {
                        'f': 'toggleFilterBtn',
                        's': 'searchInput',
                        'e': 'exportBtn',
                        'r': 'resetFilterBtn',
                        't': 'themeToggle'
                    };
                    const key = e.key.toLowerCase();
                    if (map[key]) {
                        const btn = document.getElementById(map[key]);
                        if (btn) {
                            e.preventDefault();
                            if (key === 's') btn.focus();
                            else btn.click();
                        }
                    }
                }

                if (!inInput && e.key === '/') {
                    e.preventDefault();
                    document.getElementById('searchInput').focus();
                }
            });

            // INITIALIZATION
            attachRowEvents(); applyColumnConfig(); updateSelectionUI();
        });
    </script>
}
