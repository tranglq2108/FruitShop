@using System.Text.Json
@model FruitShop.ViewModels.CouponList
@{
    ViewData["Title"] = "Quản lý Mã giảm giá";
    var totalCoupons = ViewBag.TotalCoupons ?? 0;
    var activeCoupons = ViewBag.ActiveCoupons ?? 0;
}

<link rel="stylesheet" href="~/css/animations.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/products.css" asp-append-version="true" />
<link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    .dark-mode .dark-green-text {
        color: #10b981 !important; /* Emerald/Green */
    }
    .dark-mode .dark-orange-text {
        color: #f59e0b !important; /* Amber/Orange */
    }
    .dark-mode .dark-label-muted {
        color: #94a3b8 !important; /* Muted Slate */
    }
</style>

@Html.AntiForgeryToken()

<div class="min-h-screen pt-0 px-6 pb-20">
    <!-- Header -->
    <div class="flex items-center justify-between mb-2">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white tracking-tight theme-contrast">Quản lý mã giảm giá</h1>
        <div class="flex items-center gap-4">
            <div class="px-4 py-2 bg-blue-600/10 border border-blue-500/20 rounded-xl flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-blue-600/20 flex items-center justify-center text-blue-400"><i class="bi bi-ticket-perforated"></i></div>
                <div><p class="text-[10px] text-gray-500 font-bold uppercase">Tổng số mã</p><p class="text-sm font-bold text-gray-900 dark:text-white theme-contrast">@totalCoupons</p></div>
            </div>
            <div class="px-4 py-2 bg-green-600/10 border border-green-500/20 rounded-xl flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-green-600/20 flex items-center justify-center text-green-400"><i class="bi bi-lightning-charge"></i></div>
                <div><p class="text-[10px] text-gray-500 font-bold uppercase">Đang chạy</p><p class="text-sm font-bold text-gray-900 dark:text-white theme-contrast">@activeCoupons</p></div>
            </div>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="flex flex-col md:flex-row items-center gap-4 mb-4">
        <div class="flex items-center gap-2">
            <div class="relative">
                <button id="actionsBtn" class="btn-primary w-full md:w-auto px-6 py-2.5" title="Phím tắt: Alt + A">
                    Hành động
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </button>
                <div id="actionsMenu" class="hidden absolute top-full left-0 mt-2 w-72 dropdown-menu rounded-xl shadow-2xl py-1 z-[9999]">
                    <button id="importBtn" class="w-full px-4 py-3 text-left hover:bg-gray-700/50 flex items-center gap-3 transition-colors">
                        <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path></svg>
                        <span class="flex-1 text-white font-medium">Nhập dữ liệu <span class="text-[10px] opacity-50 ml-1">(Alt+I)</span></span>
                    </button>
                    <div class="border-t border-gray-700/50 my-1"></div>
                    <button id="exportBtn" class="w-full px-4 py-3 text-left hover:bg-gray-700/50 flex items-center gap-3 transition-colors">
                        <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                        <span class="flex-1 text-white font-medium">Xuất dữ liệu <span class="text-[10px] opacity-50 ml-1">(Alt+E)</span></span>
                    </button>
                    <div class="border-t border-gray-700/50 my-1"></div>
                    <button id="copySelectedBtn" class="w-full px-4 py-3 text-left hover:bg-gray-700/50 flex items-center gap-3 transition-colors">
                        <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V7m-4 0h4v3m-4-7v4m-2 11h2a2 2 0 002-2v-5a2 2 0 00-2-2H5a2 2 0 00-2 2v5a2 2 0 002 2z" /></svg>
                        <span class="flex-1 text-white font-medium">Copy mã đã chọn <span class="text-[10px] opacity-50 ml-1">(Alt+K)</span></span>
                    </button>
                    <button id="deleteSelectedBtn" class="w-full px-4 py-3 text-left hover:bg-gray-700/50 flex items-center gap-3 transition-colors group">
                        <svg class="w-5 h-5 text-red-400 group-hover:text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                        <span class="flex-1 text-white font-medium">Xóa các mã đã chọn <span class="text-[10px] opacity-50 ml-1">(Alt+D)</span></span>
                    </button>
                </div>
            </div>
        </div>

        <div class="flex-1 relative flex gap-2 w-full">
            <div class="flex-1 relative">
                <svg class="w-5 h-5 absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                <input type="text" id="searchInput" placeholder="Tìm mã coupon... (Alt+S hoặc /)" class="w-full pl-10 pr-4 py-2 dark-input rounded-xl" value="@ViewData["SearchTerm"]" />
            </div>
            <select id="statusFilter" class="dark-input px-4 py-2 rounded-xl cursor-pointer min-w-[180px]">
                <option value="">Tất cả trạng thái</option>
                <option value="active" selected="@(ViewData["fStatus"]?.ToString() == "active")">Đang hiệu lực</option>
                <option value="expired" selected="@(ViewData["fStatus"]?.ToString() == "expired")">Đã hết hạn</option>
                <option value="0" selected="@(ViewData["fStatus"]?.ToString() == "0")">Đang khóa</option>
            </select>
        </div>

        <button id="addBtn" class="btn-primary px-8 py-2.5 whitespace-nowrap" title="Phím tắt: Alt + N">
            <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Tạo mã mới <span class="text-[10px] opacity-50 ml-1 font-mono">(Alt+N)</span>
        </button>
    </div>

    <!-- Table -->
    <div class="dark-card overflow-x-auto shadow-2xl">
        <table class="w-full" id="couponTable">
            <thead>
                <tr class="table-header border-b border-gray-700/50">
                    <th class="px-4 py-3 text-left w-12 sticky-col"><input type="checkbox" id="selectAll" class="w-4 h-4 cursor-pointer accent-blue-600" /></th>
                    <th class="px-4 py-3 text-left w-16 sticky-col">STT</th>
                    <th class="px-4 py-3 text-left">Mã Ưu Đãi</th>
                    <th class="px-4 py-3 text-left">Giảm giá</th>
                    <th class="px-4 py-3 text-left theme-contrast !important">Điều kiện</th>
                    <th class="px-4 py-3 text-left">Thời hạn</th>
                    <th class="px-4 py-3 text-center">Sử dụng</th>
                    <th class="px-4 py-3 text-left">Trạng thái</th>
                    <th class="px-4 py-3 text-center sticky-col-right">Thao tác</th>
                </tr>
            </thead>
            <tbody id="tableBody">
                @if (Model.Coupons != null && Model.Coupons.Any())
                {
                    int stt = ((Model.CurrentPage - 1) * Model.PageSize) + 1;
                    foreach (var item in Model.Coupons)
                    {
                        <tr class="table-row text-sm border-b border-gray-800/30 hover:bg-gray-800/20 transition-colors"
                            data-id="@item.Id" data-code="@item.Code" data-type="@item.DiscountType" data-val="@item.DiscountValue" data-limit="@item.UsageLimit" data-min="@item.MinOrderValue">
                            <td class="px-4 py-3 sticky-col"><input type="checkbox" class="couponCheckbox w-4 h-4 cursor-pointer accent-blue-600" data-id="@item.Id" /></td>
                            <td class="px-4 py-3 sticky-col text-gray-500 font-mono">@stt</td>
                            <td class="px-4 py-3">
                                <span class="px-3 py-1 bg-indigo-600/10 border border-indigo-500/20 rounded-lg text-indigo-400 font-bold tracking-widest uppercase">@item.Code</span>
                            </td>
                            <td class="px-4 py-3">
                                @if (item.DiscountType == "percent") {
                                    <div class="text-gray-900 dark-green-text font-bold">@item.DiscountValue%</div>
                                    <div class="text-[10px] text-gray-500 dark-label-muted uppercase">Phần trăm</div>
                                } else {
                                    <div class="text-green-500 dark-green-text font-bold">@(item.DiscountValue.HasValue ? item.DiscountValue.Value.ToString("N0") : "0") đ</div>
                                    <div class="text-[10px] text-gray-500 dark-label-muted uppercase">Tiền mặt</div>
                                }
                            </td>
                            <td class="px-4 py-3">
                                <div class="text-gray-900 dark-orange-text font-bold">≥ @(item.MinOrderValue.HasValue? item.MinOrderValue.Value.ToString("N0") : "0") đ</div>
                            </td>
                            <td class="px-4 py-3">
                                <div class="text-[11px] text-gray-500 dark-label-muted font-bold">Từ: @item.StartDate?.ToString("dd/MM/yyyy")</div>
                                <div class="text-[11px] text-gray-400 dark-orange-text font-bold">Đến: @item.EndDate?.ToString("dd/MM/yyyy")</div>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <div class="text-gray-900 dark:text-white font-bold">@item.UsedCount / @item.UsageLimit</div>
                                <div class="w-full bg-gray-800 h-1 rounded-full mt-1.5 overflow-hidden max-w-[80px] mx-auto border border-gray-700/50">
                                    <div class="bg-blue-600 h-full transition-all duration-500" style="width: @(item.UsageLimit > 0 ? (double)item.UsedCount / item.UsageLimit * 100 : 0)%"></div>
                                </div>
                            </td>
                            <td class="px-4 py-3">
                                @if (item.Status == 0) {
                                    <span class="px-2 py-1 rounded-full text-[10px] font-bold bg-gray-900/30 text-gray-400 border border-gray-500/20 uppercase tracking-wider">Đã khóa</span>
                                } else if (item.EndDate.HasValue && item.EndDate.Value < DateTime.Now) {
                                    <span class="px-2 py-1 rounded-full text-[10px] font-bold bg-red-900/30 text-red-400 border border-red-500/20 uppercase tracking-wider">Hết hạn</span>
                                } else if (item.StartDate.HasValue && item.StartDate.Value > DateTime.Now) {
                                    <span class="px-2 py-1 rounded-full text-[10px] font-bold bg-yellow-900/30 text-yellow-400 border border-yellow-500/20 uppercase tracking-wider">Sắp diễn ra</span>
                                } else if (item.UsageLimit.HasValue && item.UsedCount >= item.UsageLimit.Value) {
                                    <span class="px-2 py-1 rounded-full text-[10px] font-bold bg-orange-900/30 text-orange-400 border border-orange-500/20 uppercase tracking-wider">Hết lượt</span>
                                } else {
                                    <span class="px-2 py-1 rounded-full text-[10px] font-bold bg-green-900/30 text-green-400 border border-green-500/20 uppercase tracking-wider">Hoạt động</span>
                                }
                            </td>
                            <td class="px-4 py-3 text-center sticky-col-right">
                                <div class="flex items-center justify-center gap-1.5">
                                    <button type="button" class="copySingleBtn p-1.5 rounded-lg text-purple-400 hover:bg-purple-400/10 transition-all" title="Sao chép mã này">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V7m-4 0h4v3m-4-7v4m-2 11h2a2 2 0 002-2v-5a2 2 0 00-2-2H5a2 2 0 00-2 2v5a2 2 0 002 2z" /></svg>
                                    </button>
                                    <button type="button" class="editBtn p-1.5 rounded-lg text-yellow-400 hover:bg-yellow-400/10 transition-all" title="Chỉnh sửa">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                                    </button>
                                    <button type="button" class="deleteSingleBtn p-1.5 rounded-lg text-red-400 hover:bg-red-400/10 transition-all" title="Xóa" data-id="@item.Id">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        stt++;
                    }
                }
                else
                {
                    <tr><td colspan="9" class="px-5 py-16 text-center text-gray-500 font-medium">Không tìm thấy mã giảm giá nào.</td></tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="pagination-container flex flex-col items-center gap-4 mt-8">
        @if (Model.TotalPages > 1)
        {
            <div class="flex items-center justify-center gap-2">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <button data-page="@i" class="pag-btn w-10 h-10 rounded-lg flex items-center justify-center font-bold transition-all @(i == Model.CurrentPage ? "bg-blue-600 text-white shadow-lg shadow-blue-900/40" : "bg-gray-800 text-gray-400 hover:bg-gray-700 hover:text-white")">@i</button>
                }
            </div>
        }
    </div>
</div>

<!-- Modal Form -->
<div id="couponModal" class="hidden fixed inset-0 bg-black bg-opacity-70 flex items-center justify-center z-50 p-4">
    <div class="dark-card w-full max-w-2xl p-8 rounded-2xl shadow-2xl border border-gray-700 animate-fade-in max-h-[90vh] overflow-y-auto scrollbar-thin">
        <div class="flex items-center justify-between gap-4 mb-8 border-b border-gray-700/50 pb-5">
            <div class="flex items-center gap-3">
                <h3 id="modalTitle" class="text-2xl font-bold text-white tracking-tight">Tạo mã ưu đãi</h3>
                <div class="relative">
                    <button type="button" id="openPastePickerBtn" class="flex items-center gap-2 px-3 py-1.5 bg-purple-600/20 text-purple-400 border border-purple-500/30 rounded-lg text-xs font-bold hover:bg-purple-600/30 transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
                        Dán <span id="clipboardBadge" class="hidden ml-1 px-1.5 py-0.5 bg-purple-600 text-white rounded-full text-[10px]">0</span>
                    </button>
                    <div id="pasteMenu" class="hidden absolute top-full left-0 mt-2 w-64 bg-gray-800 border border-gray-700 rounded-lg shadow-2xl py-2 z-[60] max-h-64 overflow-y-auto scrollbar-thin">
                        <div class="px-3 py-1 text-[10px] text-gray-500 uppercase font-bold border-b border-gray-700 mb-1 flex justify-between items-center">
                            <span>Bảng tạm</span>
                            <button type="button" id="clearClipboard" class="text-red-400 hover:underline">Xóa hết</button>
                        </div>
                        <div id="pasteList"></div>
                    </div>
                </div>
            </div>
            <button type="button" class="close-modal text-gray-400 hover:text-white transition-colors"><svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12" /></svg></button>
        </div>
        
        <form id="couponForm" class="grid grid-cols-2 gap-x-6 gap-y-5">
            <input type="hidden" id="couponId" name="Id">
            <div class="space-y-1.5 col-span-2 md:col-span-1">
                <label class="text-sm font-semibold text-gray-300 uppercase tracking-wider text-[11px]">Mã Coupon *</label>
                <input type="text" id="couponCode" name="Code" required class="dark-input w-full p-3 rounded-lg border border-gray-600 focus:border-blue-500 font-bold text-indigo-400 tracking-widest uppercase" placeholder="VÍ DỤ: GIAM20K">
            </div>
            <div class="space-y-1.5 col-span-2 md:col-span-1">
                <label class="text-sm font-semibold text-gray-300 uppercase tracking-wider text-[11px]">Loại giảm giá</label>
                <select id="couponType" name="DiscountType" class="dark-input w-full p-3 rounded-lg border border-gray-600 cursor-pointer">
                    <option value="percent">Phần trăm (%)</option>
                    <option value="fixed">Tiền mặt (VNĐ)</option>
                </select>
            </div>
            <div class="space-y-1.5 col-span-2 md:col-span-1">
                <label class="text-sm font-semibold text-gray-300 uppercase tracking-wider text-[11px]">Giá trị giảm *</label>
                <input type="number" id="couponValue" name="DiscountValue" required class="dark-input w-full p-3 rounded-lg border border-gray-600 focus:border-blue-500" placeholder="0">
            </div>
            <div class="space-y-1.5 col-span-2 md:col-span-1">
                <label class="text-sm font-semibold text-gray-300 uppercase tracking-wider text-[11px]">Lượt dùng tối đa</label>
                <input type="number" id="couponLimit" name="UsageLimit" required class="dark-input w-full p-3 rounded-lg border border-gray-600 focus:border-blue-500" placeholder="100">
            </div>
            <div class="space-y-1.5 col-span-2 md:col-span-1">
                <label class="text-sm font-semibold text-gray-300 uppercase tracking-wider text-[11px]">Đơn tối thiểu (VNĐ)</label>
                <input type="number" id="couponMin" name="MinOrderValue" required class="dark-input w-full p-3 rounded-lg border border-gray-600 focus:border-blue-500" placeholder="0">
            </div>
            <div class="space-y-1.5 col-span-2 md:col-span-1">
                <label class="text-sm font-semibold text-gray-300 uppercase tracking-wider text-[11px]">Trạng thái</label>
                <select id="couponStatus" name="Status" class="dark-input w-full p-3 rounded-lg border border-gray-600 cursor-pointer">
                    <option value="1">Kích hoạt</option>
                    <option value="0">Khóa mã</option>
                </select>
            </div>
            <div class="space-y-1.5 col-span-2 md:col-span-1">
                <label class="text-sm font-semibold text-gray-300 uppercase tracking-wider text-[11px]">Ngày bắt đầu</label>
                <input type="date" id="couponStart" name="StartDate" class="dark-input w-full p-3 rounded-lg border border-gray-600 focus:border-blue-500">
            </div>
            <div class="space-y-1.5 col-span-2 md:col-span-1">
                <label class="text-sm font-semibold text-gray-300 uppercase tracking-wider text-[11px]">Ngày kết thúc</label>
                <input type="date" id="couponEnd" name="EndDate" class="dark-input w-full p-3 rounded-lg border border-gray-600 focus:border-blue-500">
            </div>
            
            <div class="col-span-2 flex gap-4 mt-6">
                <button type="button" class="close-modal flex-1 py-4 bg-gray-700/50 hover:bg-gray-600 text-gray-300 rounded-xl font-bold transition-all uppercase text-[11px] tracking-widest border border-gray-600/50">Hủy bỏ</button>
                <button type="submit" class="flex-[1.5] py-4 bg-blue-600 hover:bg-blue-500 text-white rounded-xl font-bold shadow-lg shadow-blue-900/20 transition-all uppercase text-[11px] tracking-widest">Lưu mã giảm giá (Ctrl+S)</button>
            </div>
        </form>
    </div>
</div>

<!-- Modal Nhập Dữ Liệu -->
<div id="importModal" class="hidden fixed inset-0 bg-black bg-opacity-70 flex items-center justify-center z-50">
    <div class="dark-card w-full max-w-lg p-8 rounded-2xl shadow-2xl border border-gray-700 animate-fade-in">
        <div class="flex items-center justify-between mb-6 border-b border-gray-700/50 pb-4">
            <h3 class="text-xl font-bold text-white flex items-center gap-2">
                <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path></svg>
                Nhập mã giảm giá
            </h3>
            <button class="close-modal text-gray-400 hover:text-white transition-colors"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"/></svg></button>
        </div>
        <div class="bg-blue-900/10 border border-blue-800/30 rounded-xl p-4 mb-6 flex items-start gap-4">
            <div class="bg-blue-600/20 p-2 rounded-lg"><svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div>
            <div class="flex-1">
                <p class="text-xs text-blue-200 leading-relaxed">Sử dụng file Excel (.xlsx) đúng định dạng. Cột yêu cầu: Mã Coupon, Loại (percent/fixed), Giá trị giảm, Số lượt dùng, Đơn tối thiểu.</p>
                <a href="/Coupons/DownloadTemplate" class="inline-flex items-center gap-1.5 mt-2 text-blue-400 text-[11px] font-bold hover:text-blue-300 transition-colors uppercase">Tải file mẫu tại đây</a>
            </div>
        </div>
        <input type="file" id="importFileInput" class="hidden" accept=".xlsx">
        <div id="importDropzone" onclick="document.getElementById('importFileInput').click()" class="w-full py-12 border-2 border-dashed border-gray-700 rounded-2xl flex flex-col items-center justify-center gap-3 cursor-pointer hover:border-blue-500 hover:bg-blue-500/5 transition-all group">
            <svg class="w-12 h-12 text-gray-500 group-hover:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            <p class="text-sm font-bold text-gray-300 group-hover:text-blue-400">Chọn hoặc kéo thả file</p>
        </div>
        <div id="filePreview" class="hidden mt-4 p-4 bg-gray-800/50 border border-gray-700 rounded-xl flex items-center justify-between">
            <div class="flex items-center gap-3"><div class="w-10 h-10 bg-green-600/20 text-green-400 rounded flex items-center justify-center font-bold text-xs uppercase">File</div><div><p id="fileName" class="text-sm text-white font-bold truncate"></p><p id="fileSize" class="text-[10px] text-gray-500"></p></div></div>
            <button type="button" id="removeImportFile" class="text-gray-500 hover:text-red-400"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"/></svg></button>
        </div>
        <div id="importResultBox" class="hidden mt-4 p-4 rounded-xl border text-[13px] max-h-48 overflow-y-auto scrollbar-thin"></div>
        <div class="flex gap-4 mt-8">
            <button class="close-modal flex-1 py-3 bg-gray-700/50 text-gray-300 rounded-xl font-bold">Hủy bỏ</button>
            <button id="importSubmitBtn" class="flex-1 py-3 bg-blue-600 text-white rounded-xl font-bold">Bắt đầu nhập</button>
        </div>
    </div>
</div>

<!-- Modal Xác nhận xóa -->
<div id="deleteConfirmModal" class="hidden fixed inset-0 bg-black bg-opacity-70 flex items-center justify-center z-50">
    <div class="dark-card w-full max-w-sm p-8 rounded-2xl border border-gray-700 text-center shadow-2xl">
        <div class="w-20 h-20 bg-red-900/20 text-red-500 rounded-full flex items-center justify-center mx-auto mb-6"><svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg></div>
        <h3 class="text-xl font-bold text-white mb-2">Xác nhận xóa bỏ?</h3>
        <p class="text-gray-400 text-sm mb-8" id="deleteConfirmMessage">Mã giảm giá sẽ bị xóa vĩnh viễn và không thể hoàn tác.</p>
        <div class="flex gap-4">
            <button class="close-modal flex-1 py-3 bg-gray-700/50 text-gray-400 rounded-xl font-bold">Quay lại</button>
            <button id="confirmDeleteBtn" class="flex-1 py-3 bg-red-600 text-white rounded-xl font-bold">Đồng ý xóa</button>
        </div>
    </div>
</div>

<div id="toastContainer" class="fixed top-4 right-4 z-[100] space-y-2"></div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            let isEditMode = false;
            let deleteTarget = null;
            let deleteType = 'single';
            const urlParams = new URLSearchParams(window.location.search);

            // --- HELPER FUNCTIONS ---
            function showToast(msg, type = 'success') {
                const container = document.getElementById('toastContainer');
                if (!container) return;
                const t = document.createElement('div');
                t.className = `dark-card px-6 py-3.5 rounded-xl border-l-4 ${type === 'success' ? 'border-blue-500' : 'border-red-500'} shadow-2xl text-white animate-fade-in mb-2 flex items-center gap-3`;
                const icon = type === 'success' ? '<svg class="w-5 h-5 text-blue-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>' : '<svg class="w-5 h-5 text-red-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>';
                t.innerHTML = `${icon} <span class="font-medium text-sm">${msg}</span>`;
                container.appendChild(t);
                setTimeout(() => { t.classList.add('opacity-0'); setTimeout(() => t.remove(), 500); }, 3000);
            }

            // --- SELECTION & CLIPBOARD ---
            document.getElementById('selectAll').onchange = function() {
                document.querySelectorAll('.couponCheckbox').forEach(cb => cb.checked = this.checked);
            };

            const CLIPBOARD_KEY = 'fruitshop_coupon_clipboard';
            const loadClipboard = () => JSON.parse(sessionStorage.getItem(CLIPBOARD_KEY)) || [];
            const updateClipboardBadge = () => {
                const n = loadClipboard().length;
                const b = document.getElementById('clipboardBadge');
                if (b) { b.innerText = n; b.classList.toggle('hidden', n === 0); }
            };
            const pushToClipboard = (snaps) => {
                let current = loadClipboard();
                snaps.forEach(item => {
                    if (!current.some(ex => ex.code === item.code)) current.unshift(item);
                });
                sessionStorage.setItem(CLIPBOARD_KEY, JSON.stringify(current.slice(0, 50)));
                updateClipboardBadge();
            };

            document.getElementById('openPastePickerBtn').onclick = (e) => {
                e.stopPropagation();
                const list = document.getElementById('pasteList');
                const items = loadClipboard();
                list.innerHTML = items.length ? '' : '<div class="px-3 py-4 text-center text-gray-500 text-xs font-bold uppercase">Trống</div>';
                items.forEach((s) => {
                    const btn = document.createElement('button');
                    btn.type = 'button';
                    btn.className = 'w-full px-3 py-2.5 text-left hover:bg-gray-700/50 border-b border-gray-700/30 transition-colors';
                    btn.innerHTML = `<div class="text-[10px] text-blue-400 font-bold font-mono">${s.code}</div><div class="text-[11px] text-gray-200 truncate font-medium">${s.discountValue}${s.discountType==='percent'?'%':'đ'}</div>`;
                    btn.onclick = () => {
                        document.getElementById('couponCode').value = s.code || '';
                        document.getElementById('couponType').value = s.discountType || 'percent';
                        document.getElementById('couponValue').value = s.discountValue || '';
                        document.getElementById('couponLimit').value = s.usageLimit || '';
                        document.getElementById('couponMin').value = s.minOrderValue || '0';
                        document.getElementById('pasteMenu').classList.add('hidden');
                        showToast('Đã dán dữ liệu');
                    };
                    list.appendChild(btn);
                });
                document.getElementById('pasteMenu').classList.toggle('hidden');
            };

            document.getElementById('clearClipboard').onclick = (e) => {
                e.stopPropagation(); sessionStorage.removeItem(CLIPBOARD_KEY); updateClipboardBadge();
                document.getElementById('pasteMenu').classList.add('hidden'); showToast('Đã xóa bảng tạm');
            };

            // --- CRUD ACTIONS ---
            function attachRowEvents() {
                document.querySelectorAll('.copySingleBtn').forEach(btn => {
                    btn.onclick = function (e) {
                        e.stopPropagation();
                        const d = this.closest('tr').dataset;
                        pushToClipboard([{
                            code: d.code, discountType: d.type, discountValue: d.val,
                            usageLimit: d.limit, minOrderValue: d.min
                        }]);
                        showToast('Đã copy mã giảm giá');
                    };
                });

                document.querySelectorAll('.editBtn').forEach(btn => {
                    btn.onclick = function() {
                        isEditMode = true; const id = this.closest('tr').dataset.id;
                        fetch(`/Coupons/GetDetails?id=${id}`).then(r => r.json()).then(res => {
                            if (res.success) {
                                const d = res.data;
                                document.getElementById('modalTitle').innerText = "Cập nhật: " + d.code;
                                document.getElementById('couponId').value = d.id;
                                document.getElementById('couponCode').value = d.code;
                                document.getElementById('couponType').value = d.discountType;
                                document.getElementById('couponValue').value = d.discountValue;
                                document.getElementById('couponLimit').value = d.usageLimit;
                                document.getElementById('couponMin').value = d.minOrderValue;
                                document.getElementById('couponStart').value = d.startDate ? d.startDate.split('T')[0] : '';
                                document.getElementById('couponEnd').value = d.endDate ? d.endDate.split('T')[0] : '';
                                document.getElementById('couponStatus').value = d.status;
                                document.getElementById('couponModal').classList.remove('hidden');
                            }
                        });
                    };
                });

                document.querySelectorAll('.deleteSingleBtn').forEach(btn => {
                    btn.onclick = function() {
                        deleteType = 'single'; deleteTarget = this.dataset.id;
                        document.getElementById('deleteConfirmMessage').innerText = "Bạn có chắc chắn muốn xóa mã giảm giá này?";
                        document.getElementById('deleteConfirmModal').classList.remove('hidden');
                    };
                });
            }

            document.getElementById('addBtn').onclick = () => {
                isEditMode = false; document.getElementById('modalTitle').innerText = "Tạo mã ưu đãi";
                document.getElementById('couponForm').reset(); document.getElementById('couponId').value = '';
                document.getElementById('couponModal').classList.remove('hidden');
            };

            document.getElementById('copySelectedBtn').onclick = () => {
                const ids = Array.from(document.querySelectorAll('.couponCheckbox:checked')).map(cb => cb.dataset.id).join(',');
                if (!ids) return showToast("Vui lòng chọn mã!", "error");
                fetch(`/Coupons/CopyAll?ids=${ids}`).then(r => r.json()).then(res => {
                    if (res.success) { pushToClipboard(res.items); showToast(`Đã copy ${res.items.length} mã`); }
                });
            };

            document.getElementById('deleteSelectedBtn').onclick = () => {
                const ids = Array.from(document.querySelectorAll('.couponCheckbox:checked')).map(cb => parseInt(cb.dataset.id));
                if (!ids.length) return showToast("Vui lòng chọn mã!", "error");
                deleteType = 'bulk'; deleteTarget = ids;
                document.getElementById('deleteConfirmMessage').innerText = `Xóa ${ids.length} mã giảm giá đã chọn?`;
                document.getElementById('deleteConfirmModal').classList.remove('hidden');
            };

            document.getElementById('confirmDeleteBtn').onclick = () => {
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                const url = deleteType === 'single' ? `/Coupons/Delete?id=${deleteTarget}` : '/Coupons/DeleteSelected';
                const body = deleteType === 'single' ? null : JSON.stringify(deleteTarget);
                const headers = { 'RequestVerificationToken': token };
                if (deleteType === 'bulk') headers['Content-Type'] = 'application/json';

                fetch(url, { method: 'POST', headers: headers, body: body }).then(r => r.json()).then(res => {
                    if (res.success) { showToast(res.message); setTimeout(() => location.reload(), 800); }
                    else showToast(res.message, 'error');
                    document.getElementById('deleteConfirmModal').classList.add('hidden');
                });
            };

            document.getElementById('couponForm').onsubmit = function(e) {
                e.preventDefault();
                const btn = this.querySelector('button[type="submit"]');
                const originalText = btn.innerHTML;
                btn.disabled = true; btn.innerText = "Đang lưu...";
                const url = isEditMode ? '/Coupons/Edit' : '/Coupons/Create';
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                fetch(url, { method: 'POST', headers: { 'RequestVerificationToken': token }, body: new FormData(this) })
                .then(r => r.json()).then(res => {
                    if (res.success) { showToast(res.message); setTimeout(() => location.reload(), 800); }
                    else { btn.disabled = false; btn.innerHTML = originalText; showToast(res.message, 'error'); }
                });
            };

            // --- UI & SEARCH ---
            function performSearch(page = 1) {
                const term = document.getElementById('searchInput').value;
                const status = document.getElementById('statusFilter').value;
                urlParams.set('searchTerm', term);
                urlParams.set('fStatus', status);
                urlParams.set('page', page);
                window.location.href = `${window.location.pathname}?${urlParams.toString()}`;
            }

            const debounce = (fn, d) => { let t; return (...a) => { clearTimeout(t); t = setTimeout(() => fn(...a), d); }; };
            document.getElementById('searchInput').oninput = debounce(() => performSearch(1), 500);
            document.getElementById('statusFilter').onchange = () => performSearch(1);

            document.getElementById('actionsBtn').onclick = (e) => { e.stopPropagation(); document.getElementById('actionsMenu').classList.toggle('hidden'); };
            document.addEventListener('click', () => {
                document.getElementById('actionsMenu').classList.add('hidden');
                document.getElementById('pasteMenu')?.classList.add('hidden');
            });
            document.querySelectorAll('.pag-btn').forEach(btn => btn.onclick = () => performSearch(btn.dataset.page));
            document.querySelectorAll('.close-modal').forEach(b => b.onclick = () => b.closest('.fixed').classList.add('hidden'));

            // KEYBOARD
            document.addEventListener('keydown', function(e) {
                const inInput = ['INPUT', 'TEXTAREA', 'SELECT'].includes(document.activeElement.tagName);
                if (e.key === 'Escape') document.querySelectorAll('.fixed:not(.hidden)').forEach(m => m.classList.add('hidden'));
                if (e.ctrlKey && e.key.toLowerCase() === 's') { e.preventDefault(); document.getElementById('couponForm')?.requestSubmit(); }
                if (e.altKey) {
                    const map = { 'n': 'addBtn', 'a': 'actionsBtn', 's': 'searchInput', 'i': 'importBtn', 'e': 'exportBtn', 'k': 'copySelectedBtn', 'd': 'deleteSelectedBtn' };
                    if (map[e.key.toLowerCase()]) { e.preventDefault(); const btn = document.getElementById(map[e.key.toLowerCase()]); if (e.key.toLowerCase() === 's') btn.focus(); else btn.click(); }
                }
            });

            // IMPORT
            document.getElementById('importBtn').onclick = () => {
                document.getElementById('importResultBox').classList.add('hidden');
                document.getElementById('importFileInput').value = '';
                document.getElementById('filePreview').classList.add('hidden');
                document.getElementById('importDropzone').classList.remove('hidden');
                document.getElementById('importModal').classList.remove('hidden');
            };

            document.getElementById('importFileInput').onchange = function(e) {
                const f = e.target.files[0];
                if (f) {
                    document.getElementById('fileName').innerText = f.name;
                    document.getElementById('fileSize').innerText = (f.size / 1024).toFixed(1) + ' KB';
                    document.getElementById('importDropzone').classList.add('hidden');
                    document.getElementById('filePreview').classList.remove('hidden');
                }
            };

            document.getElementById('importSubmitBtn').onclick = function() {
                const f = document.getElementById('importFileInput').files[0];
                if (!f) return showToast("Vui lòng chọn file!", "error");
                const formData = new FormData(); formData.append('file', f);
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                fetch('/Coupons/Import', { method: 'POST', headers: { 'RequestVerificationToken': token }, body: formData })
                .then(r => r.json()).then(res => {
                    if (res.success) { showToast(res.message); setTimeout(() => location.reload(), 800); }
                    else {
                        const box = document.getElementById('importResultBox');
                        box.className = "mt-4 p-4 bg-red-900/20 text-red-400 border border-red-700/50 rounded-xl";
                        box.innerHTML = `<div class="font-bold mb-1">${res.message}</div>${(res.errors || []).map(e => `<div>• ${e}</div>`).join('')}`;
                        box.classList.remove('hidden');
                    }
                });
            };

            document.getElementById('exportBtn').onclick = () => window.location.href = '/Coupons/ExportExcel';

            attachRowEvents();
            updateClipboardBadge();
        });
    </script>
}
