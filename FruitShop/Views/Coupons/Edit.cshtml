@model FruitShop.Models.Coupon

@{
    ViewData["Title"] = "Chỉnh sửa mã giảm giá";
}

<link rel="stylesheet" href="~/css/animations.css" asp-append-version="true" />
<link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">

<div class="min-h-screen pt-0 px-6 pb-20">
    <!-- Header -->
    <div class="flex items-center gap-4 mb-6">
        <a href="@Url.Action("Index")" class="text-gray-400 hover:text-white transition-colors p-2 rounded-lg hover:bg-gray-800">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
        </a>
        <h1 class="text-2xl font-bold text-white tracking-tight">Chỉnh sửa mã giảm giá</h1>
    </div>

    <!-- Form -->
    <div class="flex justify-center">
        <form method="post" action="@Url.Action("Edit")" class="w-full max-w-2xl">
            <div class="dark-card p-6 border border-gray-700/50 shadow-2xl rounded-xl">
                <!-- Basic Info -->
                <div class="mb-6">
                    <h2 class="text-base font-bold text-white mb-4 flex items-center gap-2">
                        <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        Thông tin mã giảm giá
                    </h2>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <!-- Mã giảm giá -->
                        <div>
                            <label class="block text-[10px] font-semibold text-gray-400 tracking-tight mb-1 uppercase">Mã giảm giá <span class="text-red-400">*</span></label>
                            <input type="text" asp-for="Code" placeholder="VD: SUMMER2024" class="dark-input w-full px-3 py-2 rounded-lg text-sm" required />
                            <span asp-validation-for="Code" class="text-red-400 text-[10px] mt-1 block"></span>
                        </div>

                        <!-- Trạng thái -->
                        <div>
                            <label class="block text-[10px] font-semibold text-gray-400 tracking-tight mb-1 uppercase">Trạng thái</label>
                            <select asp-for="Status" class="dark-input w-full px-3 py-2 rounded-lg cursor-pointer text-sm">
                                <option value="1" selected="@(Model?.Status == 1)">Hoạt động</option>
                                <option value="0" selected="@(Model?.Status == 0)">Ngưng hoạt động</option>
                            </select>
                        </div>

                        <!-- Loại giảm giá -->
                        <div>
                            <label class="block text-[10px] font-semibold text-gray-400 tracking-tight mb-1 uppercase">Loại giảm giá <span class="text-red-400">*</span></label>
                            <select asp-for="DiscountType" class="dark-input w-full px-3 py-2 rounded-lg cursor-pointer text-sm" required>
                                <option value="">-- Chọn --</option>
                                <option value="percent" selected="@(string.Equals(Model?.DiscountType, "percent", StringComparison.OrdinalIgnoreCase))">Phần trăm (%)</option>
                                <option value="fixed" selected="@(string.Equals(Model?.DiscountType, "fixed", StringComparison.OrdinalIgnoreCase))">Cố định (đ)</option>
                            </select>
                            <span asp-validation-for="DiscountType" class="text-red-400 text-[10px] mt-1 block"></span>
                        </div>

                        <!-- Giá trị giảm giá -->
                        <div>
                            <label class="block text-[10px] font-semibold text-gray-400 tracking-tight mb-1 uppercase">
                                Giá trị giảm <span class="text-red-400">*</span>
                                <span id="discountUnit" class="text-gray-500">(@(Model?.DiscountType == "FIXED" ? "đ" : "%"))</span>
                            </label>
                            <input type="number" asp-for="DiscountValue" placeholder="10" step="0.01" class="dark-input w-full px-3 py-2 rounded-lg text-sm" required />
                            <span asp-validation-for="DiscountValue" class="text-red-400 text-[10px] mt-1 block"></span>
                        </div>

                        <!-- Giảm tối đa -->
                        <div>
                            <label class="block text-[10px] font-semibold text-gray-400 tracking-tight mb-1 uppercase">Giảm tối đa (đ)</label>
                            <input type="number" asp-for="MaxDiscount" placeholder="0" step="0.01" class="dark-input w-full px-3 py-2 rounded-lg text-sm" />
                        </div>

                        <!-- Giá trị tối thiểu -->
                        <div>
                            <label class="block text-[10px] font-semibold text-gray-400 tracking-tight mb-1 uppercase">Đơn hàng tối thiểu (đ)</label>
                            <input type="number" asp-for="MinOrderValue" placeholder="0" step="0.01" class="dark-input w-full px-3 py-2 rounded-lg text-sm" />
                        </div>

                        <!-- Giới hạn sử dụng -->
                        <div class="md:col-span-2">
                            <label class="block text-[10px] font-semibold text-gray-400 tracking-tight mb-1 uppercase">Giới hạn sử dụng</label>
                            <input type="number" asp-for="UsageLimit" placeholder="0" step="1" class="dark-input w-full px-3 py-2 rounded-lg text-sm" />
                        </div>
                    </div>
                </div>

                <!-- Date Range -->
                <div class="mb-6 pb-6 border-b border-gray-700/50">
                    <h2 class="text-base font-bold text-white mb-4 flex items-center gap-2">
                        <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        Thời gian hiệu lực
                    </h2>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <!-- Ngày bắt đầu -->
                        <div>
                            <label class="block text-[10px] font-semibold text-gray-400 tracking-tight mb-1 uppercase">Ngày bắt đầu</label>
                            <input type="datetime-local" asp-for="StartDate" class="dark-input w-full px-3 py-2 rounded-lg text-sm" />
                        </div>

                        <!-- Ngày kết thúc -->
                        <div>
                            <label class="block text-[10px] font-semibold text-gray-400 tracking-tight mb-1 uppercase">Ngày kết thúc</label>
                            <input type="datetime-local" asp-for="EndDate" class="dark-input w-full px-3 py-2 rounded-lg text-sm" />
                        </div>
                    </div>
                </div>

                <!-- Info -->
                <div class="mb-6 p-3 rounded-lg bg-gray-900/30 border border-gray-700/50">
                    <div class="grid grid-cols-2 gap-4 text-[11px] text-gray-400">
                        <div><span>Tạo lúc:</span> <span class="text-gray-300 ml-1">@Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</span></div>
                        <div><span>Đã dùng:</span> <span class="text-white ml-1">@(Model.UsedCount ?? 0) / @(Model.UsageLimit ?? 0)</span></div>
                    </div>
                </div>

                <!-- Buttons -->
                <div class="flex gap-3 justify-end">
                    <a href="@Url.Action("Index")" class="px-5 py-2 rounded-lg border border-gray-700 text-gray-400 hover:bg-gray-800/50 transition-all font-medium text-sm">
                        Hủy
                    </a>
                    <button type="submit" class="btn-primary px-8 py-2 text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        Cập nhật
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<style>
    .dark-card {
        background-color: rgba(30, 41, 59, 0.8);
        backdrop-filter: blur(10px);
    }

    .dark-input {
        background-color: rgba(15, 23, 42, 0.8);
        border: 1px solid rgba(71, 85, 105, 0.3);
        color: white;
    }

    .dark-input::placeholder {
        color: rgba(107, 114, 128, 0.7);
    }

    .dark-input:focus {
        outline: none;
        border-color: rgba(96, 165, 250, 0.5);
        background-color: rgba(15, 23, 42, 1);
    }

    .btn-primary {
        background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
        border: none;
        color: white;
        border-radius: 0.75rem;
        font-weight: 600;
        transition: all 0.3s ease;
        cursor: pointer;
        box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    .btn-primary:hover {
        background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(37, 99, 235, 0.4);
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const discountType = document.querySelector('[name="DiscountType"]');

        discountType.addEventListener('change', function () {
            const unit = this.value.toLowerCase() === 'percent' ? '%' : 'đ';
            document.getElementById('discountUnit').textContent = `(${unit})`;
        });
    });
</script>
