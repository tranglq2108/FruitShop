@{
    ViewData["Title"] = "Về chúng tôi";
}

<div class="about-us-page">
    <!-- Hero Section -->
    <section class="hero-section py-5 mb-5 text-white text-center d-flex align-items-center" style="background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://images.unsplash.com/photo-1610832958506-aa56368176cf?auto=format&fit=crop&w=1920&q=80'); height: 400px; background-size: cover; background-position: center;">
        <div class="container">
            <h1 class="display-3 fw-bold mb-3 animate__animated animate__fadeInDown">Về Fruit Shop</h1>
            <p class="fs-4 animate__animated animate__fadeInUp animate__delay-1s">Mang tinh hoa trái cây thế giới đến bàn ăn gia đình bạn</p>
        </div>
    </section>

    <div class="container pb-5">
        <!-- Breadcrumb điều hướng -->
        <!-- <nav aria-label="breadcrumb" class="mb-5 pb-3 border-bottom">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted" style="font-size: 1.0rem;">Trang chủ</a></li>
                <li class="breadcrumb-item active text-success fw-bold" aria-current="page" style="font-size: 1.0rem;">Về chúng tôi</li>
            </ol>
        </nav> -->

        <!-- Story Section -->
        <div class="row align-items-center mb-5 pb-5">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="pe-lg-5">
                    <h2 class="fw-bold text-success mb-3">Câu Chuyện Thương Hiệu</h2>
                    <div class="bg-success mb-4" style="height: 3px; width: 60px;"></div>
                    <p class="fs-5 text-muted lh-lg mb-4">
                        Khởi nguồn từ niềm đam mê mãnh liệt với nông sản sạch, Fruit Shop được thành lập năm 2024 với sứ mệnh kết nối những nguồn trái cây thượng hạng từ khắp nơi trên thế giới đến với người tiêu dùng Việt Nam.
                    </p>
                    <p class="text-muted lh-lg">
                        Chúng tôi hiểu rằng, mỗi trái quả không chỉ là thực phẩm, mà còn là lời cam kết về sức khỏe và sự tận hưởng cuộc sống. Chính vì vậy, đội ngũ Fruit Shop đã không ngừng tìm kiếm và tuyển chọn những vùng trồng đạt chuẩn quốc tế (GlobalGAP, Organic) để đảm bảo từng sản phẩm khi đến tay khách hàng luôn ở trạng thái hoàn hảo nhất.
                    </p>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="rounded-4 overflow-hidden shadow-lg position-relative">
                    <img src="https://images.unsplash.com/photo-1519996529931-28324d5a630e?auto=format&fit=crop&w=800&q=80" class="img-fluid w-100" alt="Fresh Vibrant Fruits" style="height: 450px; object-fit: cover;">
                    <div class="position-absolute top-0 end-0 p-4">
                        <div class="bg-white rounded-circle p-3 shadow-sm d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                            <i class="fas fa-award text-warning fs-1"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Core Values -->
        <section class="bg-pastel-green rounded-5 py-5 px-4 mb-5 shadow-sm text-center">
            <h2 class="fw-bold mb-5">Giá Trị Cốt Lõi</h2>
            <div class="row g-4">
                <div class="col-md-3 col-6">
                    <div class="value-card p-4 h-100 transition-up">
                        <div class="icon-wrap bg-white rounded-circle shadow-sm mx-auto mb-4 d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                            <i class="fas fa-leaf text-success fs-2"></i>
                        </div>
                        <h5 class="fw-bold">Tươi Sạch</h5>
                        <p class="small text-muted mb-0">Tuyển chọn nghiêm ngặt từ vùng trồng đạt chuẩn.</p>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="value-card p-4 h-100 transition-up">
                        <div class="icon-wrap bg-white rounded-circle shadow-sm mx-auto mb-4 d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                            <i class="fas fa-heart text-danger fs-2"></i>
                        </div>
                        <h5 class="fw-bold">Tận Tâm</h5>
                        <p class="small text-muted mb-0">Luôn đặt khách hàng làm trọng tâm phục vụ.</p>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="value-card p-4 h-100 transition-up">
                        <div class="icon-wrap bg-white rounded-circle shadow-sm mx-auto mb-4 d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                            <i class="fas fa-lightbulb text-warning fs-2"></i>
                        </div>
                        <h5 class="fw-bold">Sáng Tạo</h5>
                        <p class="small text-muted mb-0">Không ngừng cải tiến dịch vụ & bao bì quà tặng.</p>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="value-card p-4 h-100 transition-up">
                        <div class="icon-wrap bg-white rounded-circle shadow-sm mx-auto mb-4 d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                            <i class="fas fa-users text-primary fs-2"></i>
                        </div>
                        <h5 class="fw-bold">Trách Nhiệm</h5>
                        <p class="small text-muted mb-0">Cam kết vì cộng đồng và sự phát triển bền vững.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Stats Section -->
        <div class="row text-center g-4 mb-5">
            <div class="col-md-3 col-6 border-end">
                <h2 class="fw-bold text-success mb-1">5000+</h2>
                <p class="text-muted text-uppercase small fw-bold">Khách hàng tin dùng</p>
            </div>
            <div class="col-md-3 col-6 border-end">
                <h2 class="fw-bold text-success mb-1">50+</h2>
                <p class="text-muted text-uppercase small fw-bold">Vùng trồng hợp tác</p>
            </div>
            <div class="col-md-3 col-6 border-end">
                <h2 class="fw-bold text-success mb-1">200+</h2>
                <h2 class="fw-bold text-success mb-1">Loại trái cây</h2>
                <p class="text-muted text-uppercase small fw-bold">Sản phẩm đa dạng</p>
            </div>
            <div class="col-md-3 col-6">
                <h2 class="fw-bold text-success mb-1">10+</h2>
                <p class="text-muted text-uppercase small fw-bold">Đối tác quốc tế</p>
            </div>
        </div>

        <!-- Call to Action -->
        <div class="text-center py-5">
            <h3 class="fw-bold mb-4">Bạn đã sẵn sàng thưởng thức vị tươi ngon chưa?</h3>
            <a asp-controller="Home" asp-action="Index" class="btn btn-success btn-lg px-5 py-3 rounded-pill fw-bold shadow-lg transition-scale">Khám Phá Cửa Hàng Ngay</a>
        </div>
    </div>
</div>

<style>
    .transition-up { transition: all 0.3s ease; }
    .transition-up:hover { transform: translateY(-10px); }
    .transition-scale { transition: all 0.3s ease; }
    .transition-scale:hover { transform: scale(1.05); }
    .bg-pastel-green { background-color: #f0f9eb; }
</style>
