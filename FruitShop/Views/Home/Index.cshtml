@model FruitShop.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Trang chủ";
}

<!-- Hero Banner Section -->
<section class="hero-banner mb-5">
    <div id="mainCarousel" class="carousel slide" data-bs-ride="carousel">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#mainCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
            <button type="button" data-bs-target="#mainCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
            <button type="button" data-bs-target="#mainCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
            <button type="button" data-bs-target="#mainCarousel" data-bs-slide-to="3" aria-label="Slide 4"></button>
        </div>
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="/Upload/slide_1_mb.png" class="d-block w-100" alt="Banner 1" style="height: 700px; object-fit: cover;">
            </div>
            <div class="carousel-item">
                <img src="/Upload/slide_2_mb.png" class="d-block w-100" alt="Banner 2" style="height: 700px; object-fit: cover;">
                <div class="carousel-caption top-50 translate-middle-y d-block text-start p-0 m-0" style="left: 10%;">
                    <h1 class="display-2 fw-bold text-white mb-3" style="text-shadow: 2px 2px 15px rgba(0,0,0,0.6);">Sức Khỏe Mỗi Ngày</h1>
                    <p class="fs-3 text-white mb-4" style="text-shadow: 1px 1px 8px rgba(0,0,0,0.6);">Cung cấp vitamin và dưỡng chất thiết yếu cho gia đình bạn.</p>
                    <a href="#" class="btn btn-success btn-lg px-5 py-3 rounded-pill fw-bold shadow-lg">Xem Ưu Đãi</a>
                </div>
            </div>
            <div class="carousel-item">
                <img src="/Upload/slide_3_mb.png" class="d-block w-100" alt="Banner 3" style="height: 700px; object-fit: cover;">
            </div>
            <div class="carousel-item">
                <img src="/Upload/slide_4_mb.jpg" class="d-block w-100" alt="Banner 4" style="height: 700px; object-fit: cover;">
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#mainCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#mainCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>
</section>

<div class="container">
    <!-- Why Choose Us -->
    <section class="py-5 bg-pastel-green rounded-4 mb-5">
        <div class="row g-4 text-center px-4">
            <div class="col-6 col-lg-3">
                <i class="fas fa-shipping-fast fs-2 text-success mb-3"></i>
                <h5 class="fw-bold">Giao Hàng Nhanh</h5>
                <p class="text-muted small mb-0">Giao hàng trong 2h tại nội thành.</p>
            </div>
            <div class="col-6 col-lg-3">
                <i class="fas fa-check-circle fs-2 text-success mb-3"></i>
                <h5 class="fw-bold">Chất Lượng</h5>
                <p class="text-muted small mb-0">Kiểm định chất lượng nghiêm ngặt.</p>
            </div>
            <div class="col-6 col-lg-3">
                <i class="fas fa-shield-alt fs-2 text-success mb-3"></i>
                <h5 class="fw-bold">Hoàn Tiền 100%</h5>
                <p class="text-muted small mb-0">Đổi trả hoặc hoàn tiền nếu không hài lòng.</p>
            </div>
            <div class="col-6 col-lg-3">
                <i class="fas fa-headset fs-2 text-success mb-3"></i>
                <h5 class="fw-bold">Hỗ Trợ 24/7</h5>
                <p class="text-muted small mb-0">Sẵn sàng giải đáp mọi thắc mắc.</p>
            </div>
        </div>
    </section>

    <!-- Featured Products Section -->
    <section class="mb-5">
        <div class="row mb-5">
            <div class="col-12">
                <div class="rounded-4 overflow-hidden shadow-sm bestseller-banner-container" style="height: 350px;">
                    <img src="/Upload/image_bestseller.jpg" class="w-100 h-100" alt="Bestseller Banner" style="object-fit: cover;">
                </div>
            </div>
        </div>
        <div class="text-center mb-4">
            <h2 class="fw-bold">Sản Phẩm Bán Chạy</h2>
            <div class="bg-success mx-auto" style="height: 3px; width: 60px;"></div>
        </div>
        <div class="row g-4" id="featured-products-container">
            @for (int i = 0; i < Model.FeaturedProducts.Count; i++)
            {
                var product = Model.FeaturedProducts[i];
                var productImageUrl = product.ProductImages.FirstOrDefault(pi => pi.IsMain == 1)?.ImageUrl 
                                    ?? product.ProductImages.FirstOrDefault()?.ImageUrl 
                                    ?? "https://via.placeholder.com/300x300?text=" + product.Name;
                var approvedReviews = product.Reviews?.Where(r => r.Status == 1 && r.Rating.HasValue).ToList() ?? new List<FruitShop.Models.Review>();
                var reviewCount = approvedReviews.Count;
                var averageRating = reviewCount > 0 ? approvedReviews.Average(r => r.Rating!.Value) : 0;
                var fullStars = (int)Math.Floor(averageRating);
                var hasHalfStar = averageRating - fullStars >= 0.5;
                //..
                <div class="col-6 col-lg-3 product-item @(i >= 8 ? "d-none" : "")">
                    <div class="card h-100 border-0 shadow-sm product-card">
                        <div class="position-relative overflow-hidden product-image-wrap">
                        <!-- thử ảnh -->
                            <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="d-block h-100">
                                <img src="@productImageUrl" class="card-img-top p-3 product-image" alt="@product.Name" style="aspect-ratio: 1/1; object-fit: contain;">
                            </a>
                            @if (product.DiscountPercent > 0)
                            {
                                <span class="product-discount-badge">
                                    -@Math.Round(product.DiscountPercent.Value)%
                                </span>
                            }
                        </div>
                        <div class="card-body text-center pt-0 product-body">
                            <p class="text-muted small mb-1 product-origin">@product.Origin</p>
                            <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="text-decoration-none text-dark">
                                <h6 class="card-title fw-bold mb-2 product-title">@product.Name</h6>
                            </a>
                            <div class="product-rating mb-2">
                                @if (reviewCount > 0)
                                {
                                    <div class="rating-stars" aria-label="@averageRating.ToString("0.0") trên 5 sao">
                                        @for (int s = 1; s <= 5; s++)
                                        {
                                            if (s <= fullStars)
                                            {
                                                <span class="star star-full">&#9733;</span>
                                            }
                                            else if (s == fullStars + 1 && hasHalfStar)
                                            {
                                                <span class="star star-half">&#9733;</span>
                                            }
                                            else
                                            {
                                                <span class="star star-empty">&#9734;</span>
                                            }
                                        }
                                    </div>
                                    <span class="rating-text">@averageRating.ToString("0.0")</span>
                                }
                                else
                                {
                                    <span class="rating-text text-muted">Chưa có đánh giá</span>
                                }
                            </div>
                            <div class="mb-3 product-price">
                                @if (product.DiscountPercent > 0)
                                {
                                    <span class="text-success fw-bold fs-5">@product.FinalPrice?.ToString("N0") đ</span>
                                    <span class="text-muted text-decoration-line-through small ms-2">@product.Price?.ToString("N0") đ</span>
                                }
                                else
                                {
                                    <span class="text-success fw-bold fs-5">@product.Price?.ToString("N0") đ</span>
                                }
                            </div>
                            <button class="btn-buy-now" type="button" onclick="quickBuy(@product.Id, '@product.Name')">
                                <i class="fas fa-bolt"></i>Mua ngay
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
        @if (Model.FeaturedProducts.Count > 8)
        {
            <div class="text-center mt-5">
                <button id="btn-see-more" class="btn btn-outline-success px-5 py-2 rounded-pill fw-bold">Xem Thêm</button>
