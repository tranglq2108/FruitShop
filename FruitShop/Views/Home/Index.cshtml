@section Scripts {
<script>
    // Hàm thiết lập sự kiện cho nút Xem Thêm
    function setupSeeMore(btnId, viewAllId, itemClass) {
        document.getElementById(btnId)?.addEventListener('click', function() {
            const hiddenItems = document.querySelectorAll('.' + itemClass + '.d-none');
            // Hiện thêm tối đa 4 sản phẩm (thêm 1 hàng nữa)
            for (let i = 0; i < 4 && i < hiddenItems.length; i++) {
                hiddenItems[i].classList.remove('d-none');
            }
            
            // Nếu không còn sản phẩm nào bị ẩn, thì ẩn nút Xem Thêm và hiện nút Xem Tất Cả
            if (document.querySelectorAll('.' + itemClass + '.d-none').length === 0) {
                this.classList.add('d-none');
                document.getElementById(viewAllId)?.classList.remove('d-none');
            }
        });
    }

    // Thiết lập cho từng mục: Featured, Imported, Local, Gift
    setupSeeMore('btn-see-more', 'btn-view-all', 'product-item');
    setupSeeMore('btn-see-more-imported', 'btn-view-all-imported', 'imported-item');
    setupSeeMore('btn-see-more-local', 'btn-view-all-local', 'local-item');
    setupSeeMore('btn-see-more-gift', 'btn-view-all-gift', 'gift-item');

    // Hàm hiển thị toast notification
    function showToast(message, type) {
        // Tạo container nếu chưa có
        let toastContainer = document.getElementById('toastContainer');
        if (!toastContainer) {
            toastContainer = document.createElement('div');
            toastContainer.id = 'toastContainer';
            toastContainer.style.cssText = 'position: fixed; top: 20px; right: 20px; z-index: 9999;';
            document.body.appendChild(toastContainer);
        }

        // Tạo toast element - tạo để hiển thị thông báo với màu sắc và kiểu dáng dựa trên loại thông báo (warning, success, error)
        const toast = document.createElement('div');
        const bgColor = type === 'warning' ? '#ffc107' : (type === 'success' ? '#28a745' : '#dc3545');
        const textColor = type === 'warning' ? '#000' : '#fff';
        
        toast.style.cssText = `
            background-color: ${bgColor};
            color: ${textColor};
            padding: 15px 20px;
            border-radius: 5px;
            margin-bottom: 10px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            animation: slideIn 0.3s ease-in-out;
            max-width: 350px;
            font-weight: 500;
        `;
        
        toast.textContent = message;
        toastContainer.appendChild(toast);

        // Xóa toast sau 3 giây
        setTimeout(() => {
            toast.style.animation = 'slideOut 0.3s ease-in-out';
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    }

    // Quick buy function - redirect to product details or checkout
    function quickBuy(productId, productName) {
        const quantity = 1;

        if (typeof isAuthenticated !== 'undefined' && !isAuthenticated) {
            localStorage.setItem('pendingQuickBuyProduct', productId);
            localStorage.setItem('pendingQuickBuyQuantity', quantity);
            showLoginRequiredModal('Vui lòng đăng nhập để mua sản phẩm.');
            return;
        }

        fetch('/Cart/AddToCart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId: productId, quantity: quantity })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                sessionStorage.setItem('selectedProducts', JSON.stringify([productId]));
                // Chuyển đến trang Checkout với ID sản phẩm vừa thêm
                window.location.href = '/Cart/Checkout?selectedItems=' + productId;
            } else if (data.requireLogin) {
                localStorage.setItem('pendingQuickBuyProduct', productId);
                localStorage.setItem('pendingQuickBuyQuantity', quantity);
                showLoginRequiredModal('Vui lòng đăng nhập để mua sản phẩm.');
            } else {
                Swal.fire({ icon: 'error', title: 'Lỗi!', text: data.message || 'Có lỗi xảy ra', toast: true, position: 'top-end', timer: 3000, showConfirmButton: false, timerProgressBar: true });
            }
        })
        .catch(err => {
            console.error('Quick buy error:', err);
            Swal.fire({ icon: 'error', title: 'Lỗi!', text: 'Có lỗi xảy ra khi kết nối đến máy chủ', toast: true, position: 'top-end', timer: 3000, showConfirmButton: false, timerProgressBar: true });
        });
    }
</script>
}

