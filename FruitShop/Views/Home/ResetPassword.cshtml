@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="login-container">
    <div class="login-box">
        <h2 class="login-title">Mật Khẩu Mới</h2>
        <p class="text-muted text-center mb-4">Vui lòng nhập mật khẩu mới cho tài khoản của bạn.</p>

        <form method="post" action="@Url.Action("ResetPassword", "Home")" id="resetPasswordForm">
            <div class="mb-3">
                <label for="NewPassword" class="form-label">Mật khẩu mới</label>
                <input type="password"
                       name="NewPassword"
                       id="NewPassword"
                       class="form-control"
                       placeholder="Nhập mật khẩu mới"
                       required>
            </div>

            <div class="mb-3">
                <label for="ConfirmPassword" class="form-label">Xác nhận mật khẩu</label>
                <input type="password"
                       name="ConfirmPassword"
                       id="ConfirmPassword"
                       class="form-control"
                       placeholder="Nhập lại mật khẩu mới"
                       required>
            </div>

            <button type="submit" class="btn btn-login w-100 mb-3">Cập nhật mật khẩu</button>

            <div class="login-footer">
                <p><a href="@Url.Action("Login", "Home")">Quay lại đăng nhập</a></p>
            </div>
        </form>
    </div>
</div>

<style>
    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
        background: linear-gradient(135deg, #198754 0%, #157347 100%);
        padding: 20px;
    }

    .login-box {
        background: white;
        padding: 40px;
        border-radius: 10px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
        width: 100%;
        max-width: 400px;
    }

    .login-title {
        text-align: center;
        color: #333;
        margin-bottom: 10px;
        font-weight: 600;
    }

    .form-label {
        color: #555;
        font-weight: 500;
        margin-bottom: 8px;
    }

    .form-control {
        border: 2px solid #e0e0e0;
        border-radius: 5px;
        padding: 10px 15px;
        font-size: 14px;
        transition: all 0.3s ease;
    }

    .form-control:focus {
        border-color: #198754;
        box-shadow: 0 0 0 0.2rem rgba(25, 135, 84, 0.25);
    }

    .btn-login {
        background: linear-gradient(135deg, #198754 0%, #157347 100%);
        color: white;
        border: none;
        padding: 12px;
        font-weight: 600;
        border-radius: 5px;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .btn-login:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(25, 135, 84, 0.4);
    }

    .login-footer {
        text-align: center;
        margin-top: 20px;
        font-size: 14px;
    }

    .login-footer a {
        color: #667eea;
        text-decoration: none;
        font-weight: 600;
        transition: color 0.3s ease;
    }

    .login-footer a:hover {
        color: #764ba2;
        text-decoration: underline;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('resetPasswordForm');
            const error = '@Html.Raw(ViewBag.Error)';
            
            if (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Lỗi',
                    text: error,
                    confirmButtonColor: '#198754'
                });
            }

            form.addEventListener('submit', function(e) {
                const pass = document.getElementById('NewPassword').value;
                const confirm = document.getElementById('ConfirmPassword').value;
                
                if (pass !== confirm) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'warning',
                        title: 'Thông báo',
                        text: 'Mật khẩu xác nhận không khớp!',
                        confirmButtonColor: '#198754'
                    });
                }
            });
        });
    </script>
}
