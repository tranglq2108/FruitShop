@{
    ViewData["Title"] = "Liên hệ với chúng tôi";
}

<div class="contact-page">
    <!-- Header Section -->
    <section class="py-5 mb-5 text-center bg-pastel-green">
        <div class="container">
            <h1 class="display-4 fw-bold text-success mb-3">Liên Hệ Với Fruit Shop</h1>
            <p class="lead text-muted mx-auto" style="max-width: 700px;">Chúng tôi luôn sẵn sàng lắng nghe ý kiến đóng góp và giải đáp mọi thắc mắc của bạn. Hãy kết nối với chúng tôi ngay!</p>
        </div>
    </section>

    <div class="container pb-5">
        <!-- Breadcrumb điều hướng -->
        <!-- <nav aria-label="breadcrumb" class="mb-5 pb-3 border-bottom">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted" style="font-size: 1.0rem;">Trang chủ</a></li>
                <li class="breadcrumb-item active text-success fw-bold" aria-current="page" style="font-size: 1.0rem;">Liên hệ</li>
            </ol>
        </nav> -->

        <div class="row g-5">
            <!-- Contact Information -->
            <div class="col-lg-5">
                <div class="card border-0 shadow-sm rounded-4 p-4 h-100 bg-white">
                    <h3 class="fw-bold mb-4">Thông Tin Liên Hệ</h3>
                    
                    <div class="d-flex mb-4">
                        <div class="bg-success bg-opacity-10 rounded-3 p-3 me-3 text-success">
                            <i class="fas fa-map-marker-alt fs-4"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">Địa chỉ cửa hàng</h6>
                            <p class="text-muted mb-0">123 Đường Hoa Quả, Quận Trái Cây, TP. Hà Nội</p>
                        </div>
                    </div>

                    <div class="d-flex mb-4">
                        <div class="bg-success bg-opacity-10 rounded-3 p-3 me-3 text-success">
                            <i class="fas fa-phone-alt fs-4"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">Số điện thoại</h6>
                            <p class="text-muted mb-0">0123 456 789 (Hotline 24/7)</p>
                        </div>
                    </div>

                    <div class="d-flex mb-4">
                        <div class="bg-success bg-opacity-10 rounded-3 p-3 me-3 text-success">
                            <i class="fas fa-envelope fs-4"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">Email hỗ trợ</h6>
                            <p class="text-muted mb-0">contact@fruitshop.vn</p>
                        </div>
                    </div>

                    <div class="d-flex mb-4">
                        <div class="bg-success bg-opacity-10 rounded-3 p-3 me-3 text-success">
                            <i class="fas fa-clock fs-4"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">Giờ mở cửa</h6>
                            <p class="text-muted mb-0">Thứ 2 - Chủ Nhật: 08:00 - 21:00</p>
                        </div>
                    </div>

                    <hr class="my-4 opacity-25">
                    
                    <h6 class="fw-bold mb-3">Theo dõi chúng tôi tại:</h6>
                    <div class="d-flex gap-3">
                        <a href="#" class="btn btn-outline-success rounded-circle shadow-sm"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="btn btn-outline-success rounded-circle shadow-sm"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="btn btn-outline-success rounded-circle shadow-sm"><i class="fab fa-tiktok"></i></a>
                        <a href="#" class="btn btn-outline-success rounded-circle shadow-sm"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="col-lg-7">
                <div class="card border-0 shadow-lg rounded-4 p-4 bg-white">
                    <h3 class="fw-bold mb-4">Gửi Tin Nhắn Cho Chúng Tôi</h3>
                    <form>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Họ và tên</label>
                                <input type="text" class="form-control bg-light border-0 py-3 rounded-3" placeholder="Nhập tên của bạn">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Số điện thoại</label>
                                <input type="tel" class="form-control bg-light border-0 py-3 rounded-3" placeholder="Nhập số điện thoại">
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-bold">Email</label>
                                <input type="email" class="form-control bg-light border-0 py-3 rounded-3" placeholder="Nhập địa chỉ email">
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-bold">Chủ đề</label>
                                <select class="form-select bg-light border-0 py-3 rounded-3">
                                    <option selected>Tư vấn sản phẩm</option>
                                    <option>Khiếu nại dịch vụ</option>
                                    <option>Hợp tác kinh doanh</option>
                                    <option>Khác</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-bold">Nội dung tin nhắn</label>
                                <textarea class="form-control bg-light border-0 py-3 rounded-3" rows="5" placeholder="Bạn muốn nói gì với chúng tôi?"></textarea>
                            </div>
                            <div class="col-12 mt-4">
                                <button type="submit" class="btn btn-success w-100 py-3 rounded-3 fw-bold shadow-lg transition-scale">
                                    <i class="fas fa-paper-plane me-2"></i>Gửi Tin Nhắn Ngay
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Google Maps Placeholder -->
        <div class="row mt-5 pt-4">
            <div class="col-12">
                <div class="rounded-4 overflow-hidden shadow-sm shadow-lg" style="height: 450px;">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3724.097063412842!2d105.804812315332!3d21.028784693153!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3135ab424a50fff9%3A0x83a312969f5d7cf7!2zMTI0IFAuIExp4buZdSBHaWFpLCBOZ-G7WMgS2jDoW5oLCBCYSDEkMOsbmgsIEjDoCBO4buZaSwgVmlldG5hbQ!5e0!3m2!1sen!2s!4v1649665000000!5m2!1sen!2s" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-pastel-green { background-color: #f0f9eb; }
    .transition-scale { transition: all 0.3s ease; }
    .transition-scale:hover { transform: scale(1.02); }
    .form-control:focus, .form-select:focus {
        background-color: #fff !important;
        box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.15);
        border: 1px solid #198754 !important;
    }
</style>
