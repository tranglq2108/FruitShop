<div id="toastContainer" class="fixed top-4 right-4 z-[100] space-y-2"></div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            let isEditMode = false;
            let deleteTarget = null;
            let deleteType = 'single';
            let selectedExportFormat = 'excel';
            const urlParams = new URLSearchParams(window.location.search);

            // --- HELPER FUNCTIONS ---
            function showToast(msg, type = 'success') {
                const container = document.getElementById('toastContainer');
                if (!container) return;
                const t = document.createElement('div');
                t.className = `dark-card px-6 py-3.5 rounded-xl border-l-4 ${type === 'success' ? 'border-blue-500' : 'border-red-500'} shadow-2xl text-white animate-fade-in mb-2 flex items-center gap-3`;
                const icon = type === 'success' ? '<svg class="w-5 h-5 text-blue-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>' : '<svg class="w-5 h-5 text-red-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>';
                t.innerHTML = `${icon} <span class="font-medium text-sm">${msg}</span>`;
                container.appendChild(t);
                setTimeout(() => {
                    t.classList.add('opacity-0');
                    setTimeout(() => t.remove(), 500);
                }, 3000);
            }

            // --- CLIPBOARD LOGIC ---
            const CLIPBOARD_KEY = 'fruitshop_category_clipboard';
            const loadClipboard = () => { try { return JSON.parse(sessionStorage.getItem(CLIPBOARD_KEY)) || []; } catch { return []; } };
            const updateClipboardBadge = () => {
                const n = loadClipboard().length;
                const b = document.getElementById('clipboardBadge');
                if (b) { b.innerText = n; b.classList.toggle('hidden', n === 0); }
            };
            const pushToClipboard = (snaps) => {
                const arr = snaps.concat(loadClipboard()).slice(0, 50);
                sessionStorage.setItem(CLIPBOARD_KEY, JSON.stringify(arr));
                updateClipboardBadge();
            };

            document.getElementById('openPastePickerBtn').onclick = (e) => {
                e.stopPropagation();
                const list = document.getElementById('pasteList');
                const items = loadClipboard();
                list.innerHTML = items.length ? '' : '<div class="px-3 py-4 text-center text-gray-500 text-xs uppercase font-bold tracking-widest">Trống</div>';
                items.forEach((s, idx) => {
                    const btn = document.createElement('button');
                    btn.type = 'button';
                    btn.className = 'w-full px-3 py-2.5 text-left hover:bg-gray-700/50 border-b border-gray-700/30 last:border-0 transition-colors group';
                    btn.innerHTML = `<div class="text-[11px] text-gray-200 font-medium truncate">${s.name || 'Danh mục'}</div>`;
                    btn.onclick = () => {
                        document.getElementById('categoryName').value = s.name || '';
                        document.getElementById('categoryParent').value = s.parentId || '';
                        document.getElementById('categoryStatus').checked = s.status == 1;
                        document.getElementById('pasteMenu').classList.add('hidden');
                        showToast('Đã dán dữ liệu từ bảng tạm');
                    };
                    list.appendChild(btn);
                });
                document.getElementById('pasteMenu').classList.toggle('hidden');
            };

            document.getElementById('clearClipboard').onclick = (e) => {
                e.stopPropagation();
                sessionStorage.removeItem(CLIPBOARD_KEY);
                updateClipboardBadge();
                document.getElementById('pasteMenu').classList.add('hidden');
                showToast('Đã xóa sạch bảng tạm');
            };

            // --- SEARCH & FILTER AJAX ---
            function performSearch(page = 1) {
                const term = document.getElementById('searchInput').value;
                urlParams.set('searchTerm', term);
                urlParams.set('page', page);

                const filterIds = ['fParentId', 'fStatus'];
                filterIds.forEach(id => {
                    const el = document.getElementById(id);
                    if (el && el.value) urlParams.set(id, el.value);
                    else urlParams.delete(id);
                });

                const newUrl = `${window.location.pathname}?${urlParams.toString()}`;
                window.history.pushState({ path: newUrl }, '', newUrl);

                const tableBody = document.getElementById('tableBody');
                if (tableBody) tableBody.style.opacity = '0.5';

                fetch(newUrl)
                    .then(r => r.text())
                    .then(html => {
                        const doc = new DOMParser().parseFromString(html, 'text/html');
                        const newTableBody = doc.getElementById('tableBody');
                        const currentTableBody = document.getElementById('tableBody');
                        
                        if (newTableBody && currentTableBody) {
                            currentTableBody.innerHTML = newTableBody.innerHTML;
                            currentTableBody.style.opacity = '1';
                        }

                        const newPag = doc.querySelector('.pagination-container');
                        const pagCont = document.querySelector('.pagination-container');
                        if (newPag && pagCont) pagCont.innerHTML = newPag.innerHTML;

                        attachRowEvents();
                    })
                    .catch(err => {
                        if (tableBody) tableBody.style.opacity = '1';
                        showToast("Lỗi khi tải dữ liệu: " + err.message, 'error');
                    });
            }

            const debounce = (fn, d) => { let t; return (...a) => { clearTimeout(t); t = setTimeout(() => fn(...a), d); }; };
            document.getElementById('searchInput').oninput = debounce(() => performSearch(1), 300);

            document.getElementById('applyFilterBtn').onclick = () => {
                document.getElementById('filterPanel').classList.add('hidden');
                performSearch(1);
            };

            document.getElementById('resetFilterBtn').onclick = () => {
                document.querySelectorAll('#filterPanel select').forEach(i => i.value = '');
                performSearch(1);
            };

            // --- EXPORT LOGIC ---
            document.getElementById('exportBtn').onclick = () => {
                const count = document.querySelectorAll('.categoryCheckbox:checked').length;
                document.getElementById('exportSelectedCount').innerText = count;
                document.getElementById('exportModal').classList.remove('hidden');
            };

            document.querySelectorAll('.export-fmt-btn').forEach(btn => {
                btn.onclick = function () {
                    selectedExportFormat = this.dataset.format;
                    document.querySelectorAll('.export-fmt-btn').forEach(b => {
                        const active = b.dataset.format === selectedExportFormat;
                        b.classList.toggle('selected', active);
                        b.classList.toggle('border-green-500', active);
                        b.classList.toggle('bg-green-900/20', active);
                        b.classList.toggle('text-white', active);
                        b.classList.toggle('border-gray-700/50', !active);
                        b.classList.toggle('bg-gray-800/50', !active);
                        b.classList.toggle('text-gray-400', !active);
                    });
                };
            });

            document.getElementById('doExportBtn').onclick = function () {
                const scope = document.querySelector('input[name="exportScope"]:checked').value;
                const selected = document.querySelectorAll('.categoryCheckbox:checked');

                if (scope === 'selected' && selected.length === 0) {
                    return showToast("Vui lòng chọn ít nhất một danh mục!", "error");
                }

                let url = '';
                switch (selectedExportFormat) {
                    case 'excel': url = '/Categories/ExportExcel'; break;
                    case 'csv': url = '/Categories/ExportCsv'; break;
                    case 'json': url = '/Categories/ExportJson'; break;
                    case 'xml': url = '/Categories/ExportXml'; break;
                }

                if (scope === 'selected') {
                    const ids = Array.from(selected).map(cb => cb.dataset.id).join(',');
                    url += `?ids=${ids}`;
                }

                window.location.href = url;
                document.getElementById('exportModal').classList.add('hidden');
                showToast(`Đang xuất file ${selectedExportFormat.toUpperCase()}...`);
            };

            // --- IMPORT LOGIC ---
            const importInput = document.getElementById('importFileInput');
            const filePreview = document.getElementById('filePreview');
            const dropzone = document.getElementById('importDropzone');

            document.getElementById('importBtn').onclick = () => {
                document.getElementById('importResultBox').classList.add('hidden');
                importInput.value = '';
                filePreview.classList.add('hidden');
                dropzone.classList.remove('hidden');
                document.getElementById('importModal').classList.remove('hidden');
            };

            importInput.onchange = function (e) {
                const file = e.target.files[0];
                if (file) {
                    document.getElementById('fileName').innerText = file.name;
                    document.getElementById('fileSize').innerText = (file.size / 1024).toFixed(1) + ' KB';
                    dropzone.classList.add('hidden');
                    filePreview.classList.remove('hidden');
                }
            };

            document.getElementById('removeImportFile').onclick = () => {
                importInput.value = '';
                filePreview.classList.add('hidden');
                dropzone.classList.remove('hidden');
            };

            document.getElementById('importSubmitBtn').onclick = function () {
                const file = importInput.files[0];
                if (!file) return showToast("Vui lòng chọn file!", "error");

                const formData = new FormData();
                formData.append('file', file);
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                
                const btn = this;
                const originalText = btn.innerHTML;
                const resBox = document.getElementById('importResultBox');
                
                btn.disabled = true;
                btn.innerHTML = `<svg class="animate-spin h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> <span>Đang xử lý...</span>`;
                resBox.classList.add('hidden');
                resBox.innerHTML = '';

                fetch('/Categories/Import', { method: 'POST', headers: { 'RequestVerificationToken': token }, body: formData })
                    .then(async r => {
                        const res = await r.json();
                        btn.disabled = false;
                        btn.innerHTML = originalText;

                        if (r.ok && res.success) {
                            showToast(res.message);
                            document.getElementById('importModal').classList.add('hidden');
                            performSearch(1);
                        } else {
                            resBox.classList.remove('hidden');
                            resBox.className = "mt-4 p-4 rounded-xl border border-red-500/30 bg-red-900/10 text-red-400 text-xs font-medium max-h-48 overflow-y-auto scrollbar-thin";
                            
                            let html = `<div class="font-bold mb-2 flex items-center gap-2"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path></svg> ${res.message || 'Lỗi nhập liệu'}</div>`;
                            if (res.errors && res.errors.length) {
                                html += '<ul class="list-disc pl-5 space-y-1 mt-2">' + res.errors.map(e => `<li>${e}</li>`).join('') + '</ul>';
                            }
                            resBox.innerHTML = html;
                        }
                    })
                    .catch(err => {
                        btn.disabled = false;
                        btn.innerHTML = originalText;
                        showToast("Lỗi kết nối server", 'error');
                    });
            };

            // --- CRUD ACTIONS ---
            function attachRowEvents() {
                document.querySelectorAll('.editBtn').forEach(btn => {
                    btn.onclick = function () {
                        isEditMode = true;
                        const d = this.closest('tr').dataset;
                        document.getElementById('modalTitle').innerText = "Sửa danh mục";
                        document.getElementById('categoryId').value = d.id;
                        document.getElementById('categoryName').value = d.copyName;
                        document.getElementById('categoryParent').value = d.copyParent || '';
                        document.getElementById('categoryStatus').checked = d.copyStatus == "1";
                        document.getElementById('categoryModal').classList.remove('hidden');
                    };
                });

                document.querySelectorAll('.deleteSingleBtn').forEach(btn => {
                    btn.onclick = function () {
                        deleteType = 'single';
                        deleteTarget = this.dataset.id;
                        document.getElementById('deleteConfirmMessage').innerText = "Bạn có chắc chắn muốn xóa danh mục này? Hệ thống sẽ không cho phép xóa nếu danh mục có ràng buộc dữ liệu.";
                        document.getElementById('deleteConfirmModal').classList.remove('hidden');
                    };
                });

                document.querySelectorAll('.copySingleBtn').forEach(btn => {
                    btn.onclick = function (e) {
                        e.stopPropagation();
                        const d = this.closest('tr').dataset;
                        pushToClipboard([{
                            name: d.copyName, parentId: d.copyParent, status: d.copyStatus
                        }]);
                        showToast('Đã copy dữ liệu danh mục');
                    };
                });

                document.querySelectorAll('.viewProductsBtn').forEach(btn => {
                    btn.onclick = function () {
                        const id = this.dataset.id;
                        const modal = document.getElementById('productsPreviewModal');
                        const grid = document.getElementById('productsGrid');
                        const loader = document.getElementById('productsLoader');
                        const noMsg = document.getElementById('noProductsMsg');
                        const nameEl = document.getElementById('previewCategoryName');
                        const countEl = document.getElementById('previewProductCount');

                        modal.classList.remove('hidden');
                        loader.classList.remove('hidden');
                        grid.innerHTML = '';
                        noMsg.classList.add('hidden');
                        nameEl.innerText = 'Đang tải...';
                        countEl.innerText = 'Vui lòng chờ';

                        fetch(`/Categories/GetProductsByCategory?id=${id}`)
                            .then(r => r.json())
                            .then(res => {
                                loader.classList.add('hidden');
                                if (res.success) {
                                    nameEl.innerText = res.categoryName;
                                    countEl.innerText = `${res.products.length} sản phẩm được tìm thấy`;
                                    
                                    if (res.products.length === 0) {
                                        noMsg.classList.remove('hidden');
                                    } else {
                                        res.products.forEach(p => {
                                            const item = document.createElement('div');
                                            item.className = 'bg-gray-800/50 border border-gray-700/50 rounded-xl p-4 flex gap-4 hover:border-blue-500/50 transition-all';
                                            item.innerHTML = `
                                                <div class="w-20 h-20 bg-gray-900 rounded-lg overflow-hidden flex-shrink-0 border border-gray-700">
                                                    <img src="${p.imageUrl}" class="w-full h-full object-cover" onerror="this.src='/images/no-image.png'">
                                                </div>
                                                <div class="flex-1 min-w-0">
                                                    <p class="text-white font-bold truncate text-sm mb-1">${p.name}</p>
                                                    <p class="text-[10px] text-gray-500 uppercase tracking-widest font-bold mb-2">SKU: ${p.sku}</p>
                                                    <div class="flex items-center justify-between">
                                                        <span class="text-green-400 font-bold text-sm">${p.price.toLocaleString('vi-VN')}đ</span>
                                                        <span class="text-[10px] ${p.status == 1 ? 'text-blue-400' : 'text-red-400'} font-bold uppercase">${p.status == 1 ? 'Hoạt động' : 'Ngưng'}</span>
                                                    </div>
                                                </div>
                                            `;
                                            grid.appendChild(item);
                                        });
                                    }
                                }
                            })
                            .catch(() => {
                                loader.classList.add('hidden');
                                showToast("Không thể tải danh sách sản phẩm", 'error');
                            });
                    };
                });
            }

            document.getElementById('confirmDeleteBtn').onclick = () => {
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                const url = deleteType === 'single' ? `/Categories/Delete?id=${deleteTarget}` : '/Categories/DeleteSelected';
                const body = deleteType === 'single' ? null : JSON.stringify(deleteTarget);
                const headers = { 'RequestVerificationToken': token };
                if (deleteType === 'bulk') headers['Content-Type'] = 'application/json';

                fetch(url, { method: 'POST', headers: headers, body: body })
                    .then(r => r.json()).then(res => {
                        if (res.success) {
                            showToast(res.message);
                            performSearch(urlParams.get('page') || 1);
                        }
                        else showToast(res.message, 'error');
                        document.getElementById('deleteConfirmModal').classList.add('hidden');
                    });
            };

            document.getElementById('deleteSelectedBtn').onclick = () => {
                const ids = Array.from(document.querySelectorAll('.categoryCheckbox:checked')).map(cb => parseInt(cb.dataset.id));
                if (!ids.length) return showToast("Vui lòng chọn ít nhất một danh mục!", "error");

                deleteType = 'bulk';
                deleteTarget = ids;
                document.getElementById('deleteConfirmMessage').innerText = `Bạn có chắc muốn xóa ${ids.length} danh mục đã chọn?`;
                document.getElementById('deleteConfirmModal').classList.remove('hidden');
            };

            document.getElementById('copySelectedBtn').onclick = () => {
                const ids = Array.from(document.querySelectorAll('.categoryCheckbox:checked')).map(cb => {
                    const d = cb.closest('tr').dataset;
                    return { name: d.copyName, parentId: d.copyParent, status: d.copyStatus };
                });
                
                if (!ids.length) {
                    const btn = document.getElementById('copySelectedBtn');
                    const originalText = btn.innerHTML;
                    btn.disabled = true;
                    btn.innerHTML = `<svg class="animate-spin h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> <span>Đang lấy dữ liệu...</span>`;

                    const params = new URLSearchParams(urlParams);
                    fetch(`/Categories/CopyAll?${params.toString()}`)
                        .then(r => r.json())
                        .then(res => {
                            btn.disabled = false;
                            btn.innerHTML = originalText;
                            if (res.success && res.categories.length) {
                                pushToClipboard(res.categories);
                                showToast(`Đã copy thành công TOÀN BỘ ${res.categories.length} danh mục`);
                            } else {
                                showToast("Không có dữ liệu để copy", "error");
                            }
                        });
                    return;
                }
                
                pushToClipboard(ids);
                showToast(`Đã copy thành công ${ids.length} danh mục`);
            };

            document.getElementById('categoryForm').onsubmit = function (e) {
                e.preventDefault();
                const btn = this.querySelector('button[type="submit"]');
                btn.disabled = true;

                const formData = new FormData(this);
                if (!formData.has('Status')) formData.set('Status', '0');

                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                fetch(isEditMode ? '/Categories/Update' : '/Categories/Create', {
                    method: 'POST', headers: { 'RequestVerificationToken': token }, body: formData
                })
                    .then(r => r.json()).then(res => {
                        btn.disabled = false;
                        if (res.success) {
                            showToast(isEditMode ? "Cập nhật thành công!" : "Thêm mới thành công!");
                            document.getElementById('categoryModal').classList.add('hidden');
                            performSearch(urlParams.get('page') || 1);
                        }
                        else showToast(res.message, 'error');
                    });
            };

            // --- UI EVENTS ---
            document.getElementById('addBtn').onclick = () => {
                isEditMode = false;
                document.getElementById('modalTitle').innerText = "Thêm danh mục mới";
                document.getElementById('categoryForm').reset();
                document.getElementById('categoryId').value = '';
                document.getElementById('categoryModal').classList.remove('hidden');
            };

            document.querySelectorAll('.close-modal').forEach(b => {
                b.onclick = () => b.closest('.fixed').classList.add('hidden');
            });

            document.getElementById('actionsBtn').onclick = (e) => {
                e.stopPropagation();
                document.getElementById('actionsMenu').classList.toggle('hidden');
            };

            document.addEventListener('click', () => {
                document.getElementById('actionsMenu')?.classList.add('hidden');
                document.getElementById('pasteMenu')?.classList.add('hidden');
            });

            document.getElementById('toggleFilterBtn').onclick = () => {
                document.getElementById('filterPanel').classList.toggle('hidden');
            };

            document.getElementById('selectAll').onchange = function () {
                document.querySelectorAll('.categoryCheckbox').forEach(cb => cb.checked = this.checked);
            };

            const pagContainer = document.querySelector('.pagination-container');
            if (pagContainer) {
                pagContainer.onclick = (e) => {
                    const btn = e.target.closest('button[data-page]');
                    if (btn) performSearch(btn.dataset.page);
                };
                pagContainer.onchange = (e) => {
                    if (e.target.id === 'goToPageInput') {
                        let v = parseInt(e.target.value);
                        const max = parseInt(e.target.max);
                        if (isNaN(v) || v < 1) v = 1;
                        if (v > max) v = max;
                        e.target.value = v;
                        performSearch(v);
                    }
                };
            }

            // --- KEYBOARD SHORTCUTS ---
            document.addEventListener('keydown', function (e) {
                const inInput = ['INPUT', 'TEXTAREA', 'SELECT'].includes(document.activeElement.tagName);

                if (e.key === 'Escape') {
                    const openModals = document.querySelectorAll('.fixed:not(.hidden)');
                    if (openModals.length > 0) {
                        openModals.forEach(m => m.classList.add('hidden'));
                    } else if (inInput) {
                        document.activeElement.blur();
                    }
                    document.getElementById('pasteMenu')?.classList.add('hidden');
                }

                if (e.ctrlKey && e.key.toLowerCase() === 's') {
                    const modal = document.getElementById('categoryModal');
                    if (!modal.classList.contains('hidden')) {
                        e.preventDefault();
                        document.getElementById('categoryForm')?.requestSubmit();
                    }
                }

                if (e.altKey) {
                    const map = {
                        'n': 'addBtn', 
                        'a': 'actionsBtn', 
                        'f': 'toggleFilterBtn',
                        's': 'searchInput', 
                        'i': 'importBtn', 
                        'e': 'exportBtn',
                        'k': 'copySelectedBtn', 
                        'd': 'deleteSelectedBtn',
                        'r': 'resetFilterBtn',
                        'c': 'columnConfigBtn',
                        't': 'themeToggle'
                    };
                    const key = e.key.toLowerCase();
                    if (map[key]) {
                        const btn = document.getElementById(map[key]);
                        if (btn) {
                            e.preventDefault();
                            if (key === 's') {
                                btn.focus();
                            } else {
                                btn.click();
                            }
                        }
                    }
                }

                if (!inInput && e.key === '/') {
                    e.preventDefault();
                    document.getElementById('searchInput').focus();
                }
            });

            // --- COLUMN CONFIG ---
            const defaultCols = [
                { id: 'checkbox', name: 'Chọn', visible: true }, { id: 'stt', name: 'STT', visible: true }, 
                { id: 'column-name', name: 'Tên danh mục', visible: true }, { id: 'column-parent', name: 'Danh mục cha', visible: true }, 
                { id: 'column-status', name: 'Trạng thái', visible: true }, { id: 'actions', name: 'Thao tác', visible: true }
            ];
            let colCfg = JSON.parse(localStorage.getItem('categoryColumnConfig')) || defaultCols;

            const applyColumnConfig = () => {
                const table = document.getElementById('categoryTable');
                if (!table) return;
                const rows = table.querySelectorAll('tr');
                rows.forEach(row => {
                    colCfg.forEach(c => {
                        const cell = row.querySelector(`[data-col-id="${c.id}"]`);
                        if (cell) { cell.style.display = c.visible ? '' : 'none'; row.appendChild(cell); }
                    });
                });
            };

            let sortableInstance = null;
            document.getElementById('columnConfigBtn').onclick = () => {
                const list = document.getElementById('columnList');
                if (!list) return; list.innerHTML = '';
                colCfg.forEach((c) => {
                    const d = document.createElement('div');
                    d.className = "flex items-center gap-3 p-3 bg-gray-800/50 rounded-xl hover:bg-gray-800 transition-colors border border-gray-700/30 cursor-move group";
                    d.dataset.id = c.id;
                    d.innerHTML = `<div class="text-gray-500 group-hover:text-gray-300"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M7 2a2 2 0 11.001 3.999A2 2 0 017 2zm0 6a2 2 0 11.001 3.999A2 2 0 017 8zm0 6a2 2 0 11.001 3.999A2 2 0 017 14zm6-12a2 2 0 11.001 3.999A2 2 0 0113 2zm0 6a2 2 0 11.001 3.999A2 2 0 0113 8zm0 6a2 2 0 11.001 3.999A2 2 0 0113 14z" /></svg></div><span class="flex-1 text-sm font-medium theme-contrast">${c.name}</span><input type="checkbox" ${c.visible ? 'checked' : ''} class="col-visibility w-5 h-5 rounded accent-blue-600 cursor-pointer">`;
                    list.appendChild(d);
                });
                if (sortableInstance) sortableInstance.destroy();
                sortableInstance = new Sortable(list, { animation: 150, ghostClass: 'bg-blue-600/10' });
                document.getElementById('columnConfigModal').classList.remove('hidden');
            };

            document.getElementById('saveColumnsBtn').onclick = () => {
                const listItems = document.querySelectorAll('#columnList > div');
                const newCfg = [];
                listItems.forEach(item => {
                    const id = item.dataset.id;
                    const visible = item.querySelector('.col-visibility').checked;
                    const originalCol = defaultCols.find(dc => dc.id === id) || { name: 'N/A' };
                    newCfg.push({ id, name: originalCol.name, visible });
                });
                colCfg = newCfg; localStorage.setItem('categoryColumnConfig', JSON.stringify(colCfg));
                applyColumnConfig(); document.getElementById('columnConfigModal').classList.add('hidden');
                showToast("Đã lưu cấu hình cột");
            };

            document.getElementById('resetColumnsBtn').onclick = () => {
                colCfg = JSON.parse(JSON.stringify(defaultCols)); localStorage.removeItem('categoryColumnConfig');
                applyColumnConfig(); document.getElementById('columnConfigModal').classList.add('hidden');
                showToast("Đã khôi phục cài đặt gốc");
            };

            // --- INITIALIZATION ---
            updateClipboardBadge();
            attachRowEvents();
            applyColumnConfig();
        });
    </script>
}
