@model List<FruitShop.Models.Product>
@{
    ViewData["Title"] = "Danh sách sản phẩm";
    var currentCategoryIds = ViewBag.CurrentCategoryIds as int[] ?? new int[0];
    var currentPriceRanges = ViewBag.CurrentPriceRanges as string[] ?? new string[0];
    var currentOrigins = ViewBag.CurrentOrigins as string[] ?? new string[0];
    var origins = ViewBag.Origins as List<string> ?? new List<string>();
}

<div class="container py-5">
    <!-- Breadcrumb điều hướng -->
    <nav aria-label="breadcrumb" class="mb-4 pb-3 border-bottom">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted" style="font-size: 1.0rem;">Trang chủ</a></li>
            
            @if (ViewBag.BreadcrumbCategories != null && ((List<FruitShop.Models.Category>)ViewBag.BreadcrumbCategories).Any())
            {
                var breadcrumbs = ViewBag.BreadcrumbCategories as List<FruitShop.Models.Category>;
                for (int i = 0; i < breadcrumbs.Count; i++)
                {
                    var cat = breadcrumbs[i];
                    if (i == breadcrumbs.Count - 1)
                    {
                        <li class="breadcrumb-item active text-success fw-bold" aria-current="page" style="font-size: 1.0rem;">@cat.Name</li>
                    }
                    else
                    {
                        <li class="breadcrumb-item"><a href="javascript:void(0)" onclick="toggleRootSelection(@cat.Id)" class="text-decoration-none text-muted" style="font-size: 1.0rem;">@cat.Name</a></li>
                    }   
                }
            }
            else
            {
                <li class="breadcrumb-item active text-success fw-bold" aria-current="page" style="font-size: 1.0rem;">Tất cả sản phẩm</li>
            }
        </ol>
    </nav>

    <div class="row">
        <!-- Sidebar Filter -->
        <div class="col-lg-3">
            <!-- Danh mục -->
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                    <h5 class="fw-bold mb-0">Danh mục</h5>
                </div>
                <div class="card-body p-3">
                    <div class="category-menu">
                        <!-- Tất cả sản phẩm -->
                        <div class="category-group mb-1">
                            <a href="javascript:void(0)" onclick="clearAllFilters()" class="category-all-link fw-bold @(currentCategoryIds.Length == 0 && currentPriceRanges.Length == 0 && currentOrigins.Length == 0 ? "active" : "")">
                                Tất cả sản phẩm
                            </a>
                        </div>

                        @{
                            var allCats = ViewBag.AllCategories as List<FruitShop.Models.Category>;
                            var rootCats = ViewBag.Categories as List<FruitShop.Models.Category>;
                        }

                        @foreach (var root in rootCats)
                        {
                            var hasChildren = allCats.Any(c => c.ParentId == root.Id);
                            var isRootActive = currentCategoryIds.Contains(root.Id);
                            
                            // Kiểm tra xem có danh mục con nào đang được chọn không
                            bool IsAnyChildActive(int parentId) {
                                var children = allCats.Where(c => c.ParentId == parentId).ToList();
                                foreach(var child in children) {
                                    if (currentCategoryIds.Contains(child.Id) || IsAnyChildActive(child.Id)) return true;
                                }
                                return false;
                            }
                            var isParentOfChecked = IsAnyChildActive(root.Id);
                            
                            <div class="category-group mb-1">
                                <div class="category-root-box @(isRootActive ? "active" : "")" onclick="toggleRootSelection(@root.Id)">
                                    <input type="checkbox" class="cat-checkbox-item d-none" value="@root.Id" id="cat_@root.Id" @(isRootActive ? "checked" : "")>
                                    <span class="category-root-name flex-grow-1 fw-bold">@root.Name</span>
                                    @if (hasChildren)
                                    {
                                        <span class="category-toggle-icon" data-bs-toggle="collapse" data-bs-target="#collapse_@root.Id" onclick="event.stopPropagation()">
                                            <i class="fas fa-chevron-down"></i>
                                        </span>
                                    }
                                </div>

                                @if (hasChildren)
                                {
                                    <div class="collapse @(isRootActive || isParentOfChecked ? "show" : "")" id="collapse_@root.Id">
                                        <div class="category-sub-list ps-3 mt-1">
                                            @{
                                                var children = allCats.Where(c => c.ParentId == root.Id).ToList();
                                                // Nếu là Quà tặng (3), chỉ hiện Giỏ quà (16) và Hộp quà (17) ở cấp này
                                                if (root.Id == 3) {
                                                    children = children.Where(c => c.Id == 16 || c.Id == 17).ToList();
                                                }
                                            }

                                            @foreach (var child in children)
                                            {
                                                var isChildChecked = currentCategoryIds.Contains(child.Id);
                                                var hasGrand = allCats.Any(c => c.ParentId == child.Id) || child.Id == 16 || child.Id == 17;
                                                var isParentOfGrandChecked = IsAnyChildActive(child.Id);

                                                <div class="category-sub-group mb-1">
                                                    <div class="d-flex align-items-center category-item-wrap">
                                                        <div class="form-check custom-checkbox flex-grow-1 m-0">
                                                            <input class="form-check-input cat-checkbox-item child-check" type="checkbox" value="@child.Id" id="cat_@child.Id" @(isChildChecked ? "checked" : "") onchange="applyFilters(true)">
                                                            <label class="form-check-label text-muted small fw-semibold w-100" for="cat_@child.Id">
                                                                @child.Name
                                                            </label>
                                                        </div>
                                                        @if (hasGrand)
                                                        {
                                                            <span class="category-toggle-icon small" data-bs-toggle="collapse" data-bs-target="#collapse_sub_@child.Id">
                                                                <i class="fas fa-chevron-down"></i>
                                                            </span>
                                                        }
                                                    </div>

                                                    @if (hasGrand)
                                                    {
                                                        <div class="collapse @(isChildChecked || isParentOfGrandChecked ? "show" : "")" id="collapse_sub_@child.Id">
                                                            <div class="category-grand-list ps-3 mt-1">
                                                                @{
                                                                    var grandchildren = allCats.Where(c => c.ParentId == child.Id).ToList();
                                                                    // Ép các danh mục con vào đúng cha theo yêu cầu
                                                                    if (child.Id == 16) grandchildren = allCats.Where(c => new[] { 11, 12, 13 }.Contains(c.Id)).ToList();
                                                                    if (child.Id == 17) grandchildren = allCats.Where(c => new[] { 18, 19, 20 }.Contains(c.Id)).ToList();
                                                                }

                                                                @foreach (var grand in grandchildren)
                                                                {
                                                                    <div class="form-check custom-checkbox mb-1">
                                                                        <input class="form-check-input cat-checkbox-item child-check" type="checkbox" value="@grand.Id" id="cat_@grand.Id" @(currentCategoryIds.Contains(grand.Id) ? "checked" : "") onchange="applyFilters(true)">
                                                                        <label class="form-check-label text-muted extra-small w-100" for="cat_@grand.Id">
                                                                            @grand.Name
                                                                        </label>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Lọc theo giá -->
            <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                <h5 class="fw-bold mb-4">Mức giá</h5>
                <div class="form-check custom-checkbox mb-2">
                    <input class="form-check-input price-checkbox" type="checkbox" value="0-100000" id="price1" @(currentPriceRanges.Contains("0-100000") ? "checked" : "") onchange="applyFilters(false)">
                    <label class="form-check-label text-muted" for="price1">Dưới 100.000đ</label>
                </div>
                <div class="form-check custom-checkbox mb-2">
                    <input class="form-check-input price-checkbox" type="checkbox" value="100000-500000" id="price2" @(currentPriceRanges.Contains("100000-500000") ? "checked" : "") onchange="applyFilters(false)">
                    <label class="form-check-label text-muted" for="price2">100.000đ - 500.000đ</label>
                </div>
                <div class="form-check custom-checkbox">
                    <input class="form-check-input price-checkbox" type="checkbox" value="500000-999999999" id="price3" @(currentPriceRanges.Contains("500000-999999999") ? "checked" : "") onchange="applyFilters(false)">
                    <label class="form-check-label text-muted" for="price3">Trên 500.000đ</label>
                </div>
            </div>

            <!-- Xuất xứ -->
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <h5 class="fw-bold mb-4">Xuất xứ</h5>
                @foreach (var origin in origins)
                {
                    var originId = "origin_" + Math.Abs(origin.GetHashCode());
                    <div class="form-check custom-checkbox mb-2">
                        <input class="form-check-input origin-checkbox" type="checkbox" value="@origin" id="@originId" @(currentOrigins.Contains(origin) ? "checked" : "") onchange="applyFilters(false)">
                        <label class="form-check-label text-muted" for="@originId">@origin</label>
                    </div>
                }
            </div>
        </div>

        <!-- Product Grid Container -->
        <div class="col-lg-9" id="product-list-target">
            <partial name="_ProductGridPartial" model="Model" />
        </div>
    </div>
</div>

<!-- Bootstrap Modal for Add to Cart Confirmation -->
<div class="modal fade" id="addToCartConfirmationModal" tabindex="-1" aria-labelledby="addToCartConfirmationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
        <div class="modal-header">
            <h5 class="modal-title" id="addToCartConfirmationModalLabel">Xác nhận thêm vào giỏ hàng</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
            Bạn có muốn thêm sản phẩm <strong id="modalProductName"></strong> vào giỏ hàng không?
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
            <button type="button" class="btn btn-primary" id="confirmAddToCartButton">Thêm vào giỏ hàng</button>
        </div>
        </div>
    </div>
</div>

<!-- Scripts -->
@section Scripts {
<script>
    let currentSort = '@ViewBag.Sort' || '';
    let currentAddToCartDetails = null;

    function toggleRootSelection(id) {
        document.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = false);
        const targetCb = document.getElementById('cat_' + id);
        if (targetCb) targetCb.checked = true;
        applyFilters(false);
    }

    function applyFilters(isChildClick) {
        if (isChildClick) {
            document.querySelectorAll('.category-root-box').forEach(box => {
                const cb = box.querySelector('.cat-checkbox-item');
                if (cb) cb.checked = false;
            });
        }

        const catIds = Array.from(document.querySelectorAll('.cat-checkbox-item:checked')).map(cb => cb.value);
        const priceRanges = Array.from(document.querySelectorAll('.price-checkbox:checked')).map(cb => cb.value);
        const origins = Array.from(document.querySelectorAll('.origin-checkbox:checked')).map(cb => cb.value);
        
        loadProducts(1, catIds, priceRanges, origins, currentSort);
    }

    function clearAllFilters() {
        document.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = false);
        updateActiveStates();
        loadProducts(1, [], [], [], '');
    }

    function sortProducts(value) { currentSort = value; applyFilters(false); }
    
    function changePage(page) {
        const catIds = Array.from(document.querySelectorAll('.cat-checkbox-item:checked')).map(cb => cb.value);
        const priceRanges = Array.from(document.querySelectorAll('.price-checkbox:checked')).map(cb => cb.value);
        const origins = Array.from(document.querySelectorAll('.origin-checkbox:checked')).map(cb => cb.value);
        loadProducts(page, catIds, priceRanges, origins, currentSort);
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function loadProducts(page, catIds, priceRanges, origins, sort) {
        const urlParams = new URLSearchParams();
        catIds.forEach(id => urlParams.append('categoryIds', id));
        priceRanges.forEach(pr => urlParams.append('priceRanges', pr));
        origins.forEach(o => urlParams.append('origins', o));
        if (sort) urlParams.append('sort', sort);
        if (page > 1) urlParams.append('page', page);

        const url = '/Products/Index?' + urlParams.toString();
        window.history.pushState({}, '', url);

        const target = document.getElementById('product-list-target');
        target.style.opacity = '0.5';

        fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(res => res.text())
        .then(html => {
            target.innerHTML = html;
            target.style.opacity = '1';
            updateActiveStates();
        });
    }

    function increaseQuantity(btn) { const input = btn.parentElement.querySelector('.product-quantity'); input.value = parseInt(input.value) + 1; }
    function decreaseQuantity(btn) { const input = btn.parentElement.querySelector('.product-quantity'); if (parseInt(input.value) > 1) input.value = parseInt(input.value) - 1; }

    function addToCart(productId, productName, btn) {
        const quantity = parseInt(btn.parentElement.querySelector('.product-quantity').value) || 1;
        if (typeof isAuthenticated !== 'undefined' && !isAuthenticated) {
            localStorage.setItem('pendingCartItem', JSON.stringify({ productId, productName, quantity }));
            showLoginRequiredModal('Vui lòng đăng nhập để thêm sản phẩm vào giỏ hàng.');
            return;
        }
        currentAddToCartDetails = { productId, productName, quantity, btn };
        const modalProductNameEl = document.getElementById('modalProductName');
        if (modalProductNameEl) modalProductNameEl.textContent = productName;
        
        const modalElement = document.getElementById('addToCartConfirmationModal');
        const modal = bootstrap.Modal.getOrCreateInstance(modalElement);
        modal.show();
    }

    document.getElementById('confirmAddToCartButton')?.addEventListener('click', function() {
        const modalElement = document.getElementById('addToCartConfirmationModal');
        const modal = bootstrap.Modal.getOrCreateInstance(modalElement);
        modal.hide();
        if (!currentAddToCartDetails) return;
        const { productId, productName, quantity, btn } = currentAddToCartDetails;
        fetch('/Cart/AddToCart', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ productId, quantity }) })
        .then(res => res.json()).then(data => {
            if (data.success) {
                Swal.fire({ icon: 'success', title: 'Đã thêm ' + productName, toast: true, position: 'top-end', timer: 3000, showConfirmButton: false, timerProgressBar: true });
                
                // Cập nhật badge ngay lập tức từ dữ liệu trả về
                const badge = document.getElementById('cartBadge');
                if (badge && data.cartCount !== undefined) {
                    badge.textContent = data.cartCount;
                    badge.style.display = data.cartCount > 0 ? 'inline-block' : 'none';
                } else if (typeof updateCartCount === 'function') {
                    updateCartCount();
                }

                if (btn) {
                    const quantityInput = btn.parentElement.querySelector('.product-quantity');
                    if(quantityInput) quantityInput.value = 1;
                }
            } else if (data.requireLogin) {
                 localStorage.setItem('pendingCartItem', JSON.stringify({ productId, productName, quantity }));
                 showLoginRequiredModal('Vui lòng đăng nhập để thêm sản phẩm vào giỏ hàng.');
            } else {
                Swal.fire({ icon: 'error', title: 'Lỗi!', text: data.message || 'Không thể thêm vào giỏ hàng', toast: true, position: 'top-end', timer: 3000, showConfirmButton: false, timerProgressBar: true });
            }
        }).catch(err => {
            console.error('Error adding to cart:', err);
            Swal.fire({ icon: 'error', title: 'Lỗi!', text: 'Có lỗi xảy ra khi kết nối đến máy chủ', toast: true, position: 'top-end', timer: 3000, showConfirmButton: false, timerProgressBar: true });
        });
        currentAddToCartDetails = null;
    });

    function updateActiveStates() {
        document.querySelectorAll('.category-root-box').forEach(box => {
            const cb = box.querySelector('.cat-checkbox-item');
            if (cb && cb.checked) box.classList.add('active');
            else box.classList.remove('active');
        });
        const allBtn = document.querySelector('.category-all-link');
        const anyChecked = document.querySelectorAll('input[type="checkbox"]:checked').length > 0;
        if (!anyChecked) allBtn?.classList.add('active');
        else allBtn?.classList.remove('active');
    }

    function quickBuy(productId, productName) {
        const quantity = 1;
        if (typeof isAuthenticated !== 'undefined' && !isAuthenticated) {
            localStorage.setItem('pendingQuickBuyProduct', productId);
            localStorage.setItem('pendingQuickBuyQuantity', quantity);
            showLoginRequiredModal('Vui lòng đăng nhập để mua sản phẩm.');
            return;
        }
        fetch('/Cart/AddToCart', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ productId, quantity }) })
        .then(res => res.json()).then(data => {
            if (data.success) {
                sessionStorage.setItem('selectedProducts', JSON.stringify([productId]));
                window.location.href = '/Cart/Checkout?selectedItems=' + productId;
            } else if (data.requireLogin) {
                localStorage.setItem('pendingQuickBuyProduct', productId);
                localStorage.setItem('pendingQuickBuyQuantity', quantity);
                showLoginRequiredModal('Vui lòng đăng nhập để mua sản phẩm.');
            }
        });
    }
</script>
}

<style>
    /* CSS Giao diện chung */
    .product-card { transition: all 0.3s ease; border-radius: 15px; }
    .product-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; }
    .product-image-wrap { background: #f9fff5; height: 220px; display: flex; align-items: center; justify-content: center; }
    .product-image { max-height: 100%; object-fit: contain; }
    .product-title { min-height: 40px; font-size: 0.95rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .product-discount-badge { position: absolute; top: 0; left: 0; background: #2fa95b; color: #fff; font-size: 0.7rem; font-weight: 700; padding: 5px 10px; border-radius: 0 0 10px 0; }
    .star { font-size: 0.9rem; color: #f2b01e; }
    .star-empty { color: #d6d6d6; }

    .category-menu { display: flex; flex-direction: column; }
    .category-all-link, .category-root-box {
        display: flex; align-items: center; padding: 10px 15px; border-radius: 10px; text-decoration: none; color: #1f2937 !important; font-weight: 600; transition: all 0.2s ease; cursor: pointer;
    }
    .category-all-link:hover, .category-root-box:hover { background-color: #f3f4f6; color: #1f2937 !important; }
    .category-all-link.active, .category-root-box.active { background-color: #f0fdf4; color: #198754 !important; }
    .category-root-name { flex-grow: 1; }
    .category-item-wrap { padding: 6px 12px; border-radius: 8px; transition: all 0.2s ease; }
    .category-item-wrap:hover { background-color: #f8fafc; }
    .custom-checkbox .form-check-input { cursor: pointer; border-color: #d1d5db; }
    .custom-checkbox .form-check-input:checked { background-color: #198754; border-color: #198754; }
    .custom-checkbox .form-check-input:checked + .form-check-label { color: #198754 !important; font-weight: 700 !important; }
    .category-toggle-icon { width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; cursor: pointer; color: #9ca3af; transition: transform 0.3s ease; }
    .category-toggle-icon:hover { color: #198754; }
    [data-bs-toggle="collapse"][aria-expanded="true"] .category-toggle-icon i,
    .category-toggle-icon[aria-expanded="true"] i { transform: rotate(180deg); }
    .category-sub-list { border-left: 1px solid #e5e7eb; margin-left: 10px; }
    .category-grand-list { border-left: 1px solid #f3f4f6; margin-left: 10px; }
    .extra-small { font-size: 0.82rem; }
    .product-quantity { border: 1px solid #dee2e6; border-radius: 5px; height: 32px; text-align: center; font-weight: 600; width: 50px; -moz-appearance: textfield; }
    .product-quantity::-webkit-outer-spin-button,
    .product-quantity::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
    .product-quantity:focus { border-color: #198754; outline: none; }
    #product-list-target { transition: opacity 0.2s ease; }

    /* Pagination CSS */
    .pagination-shell { display: flex; align-items: center; justify-content: center; gap: 14px; flex-wrap: wrap; }
    .pagination-modern { gap: 6px; }
    .pagination-modern .page-link {
        min-width: 42px; height: 40px; border: 1px solid #d6e7d8; 
        border-radius: 10px !important;
        display: inline-flex; align-items: center; justify-content: center;
        font-weight: 700; color: #1f5136; background: #ffffff;
        box-shadow: 0 3px 10px rgba(16, 24, 40, 0.06); transition: all 0.18s ease;
    }
    .pagination-modern .page-item.active .page-link {
        color: #ffffff; border-color: #198754;
        background: linear-gradient(135deg, #2fa95b, #198754);
        box-shadow: 0 8px 18px rgba(25, 135, 84, 0.27);
    }
</style>