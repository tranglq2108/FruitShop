@model List<FruitShop.Models.Product>

<div id="product-grid-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">@ViewBag.CategoryName</h4>
        <select class="form-select border-0 shadow-sm rounded-3" style="width: auto;" onchange="sortProducts(this.value)">
            <option value="" selected="@(string.IsNullOrEmpty(ViewBag.Sort))">Sắp xếp mặc định</option>
            <option value="price_asc" selected="@(ViewBag.Sort == "price_asc")">Giá thấp đến cao</option>
            <option value="price_desc" selected="@(ViewBag.Sort == "price_desc")">Giá cao đến thấp</option>
            <option value="name" selected="@(ViewBag.Sort == "name")">Tên (A-Z)</option>
        </select>
    </div>

    <div class="row g-4">
        @if (Model.Count > 0)
        {
            @foreach (var product in Model)
            {
                var productImageUrl = product.ProductImages?.FirstOrDefault()?.ImageUrl;
                var approvedReviews = product.Reviews?.Where(r => r.Status == 1 && r.Rating.HasValue).ToList() ?? new List<FruitShop.Models.Review>();
                var averageRating = approvedReviews.Count > 0 ? approvedReviews.Average(r => r.Rating!.Value) : 0;
                var fullStars = (int)Math.Floor(averageRating);
                var hasHalfStar = averageRating - fullStars >= 0.5;

                <div class="col-6 col-md-4">
                    <div class="card h-100 border-0 shadow-sm product-card">
                        <a href="/Products/Details/@product.Id" class="text-decoration-none text-dark">
                            <div class="position-relative overflow-hidden product-image-wrap">
                                @if (!string.IsNullOrWhiteSpace(productImageUrl))
                                {
                                    <img src="@productImageUrl" class="card-img-top p-3 product-image" alt="@product.Name" style="aspect-ratio: 1/1; object-fit: contain;">
                                }
                                else
                                {
                                    <div class="w-100 h-100 d-flex align-items-center justify-content-center text-muted" style="aspect-ratio: 1/1;"><i class="fas fa-image"></i></div>
                                }
                                @if (product.DiscountPercent > 0)
                                {
                                    <span class="product-discount-badge">-@Math.Round(product.DiscountPercent.Value)%</span>
                                }
                            </div>
                            <div class="card-body text-center pt-0 product-body">
                                <p class="text-muted small mb-1">@product.Origin</p>
                                <h6 class="card-title fw-bold mb-2 product-title">@product.Name</h6>
                                <div class="product-rating mb-2">
                                    @if (approvedReviews.Count > 0)
                                    {
                                        <div class="rating-stars">
                                            @for (int s = 1; s <= 5; s++)
                                            {
                                                if (s <= fullStars) { <span class="star star-full">&#9733;</span> }
                                                else if (s == fullStars + 1 && hasHalfStar) { <span class="star star-half">&#9733;</span> }
                                                else { <span class="star star-empty">&#9734;</span> }
                                            }
                                        </div>
                                        <span class="rating-text">@averageRating.ToString("0.0")</span>
                                    }
                                    else { <span class="rating-text text-muted">Chưa có đánh giá</span> }
                                </div>
                                <div class="mb-3 product-price">
                                    @if (product.DiscountPercent > 0)
                                    {
                                        <span class="text-success fw-bold">@product.FinalPrice?.ToString("N0") đ</span>
                                        <span class="text-muted text-decoration-line-through small ms-2">@product.Price?.ToString("N0") đ</span>
                                    }
                                    else { <span class="text-success fw-bold">@product.Price?.ToString("N0") đ</span> }
                                </div>
                            </div>
                        </a>
                        <div class="card-body pt-0 px-3 pb-3">
                            <div class="d-flex justify-content-center align-items-center gap-2">
                                <button class="btn btn-outline-success btn-sm rounded-circle flex-shrink-0" type="button" onclick="decreaseQuantity(this)"><i class="fas fa-minus"></i></button>
                                <input type="number" class="form-control form-control-sm text-center product-quantity flex-shrink-0" value="1" min="1" style="width: 50px;" onkeypress="return event.charCode >= 48 && event.charCode <= 57" onblur="if(this.value < 1 || this.value === '') this.value = 1;">
                                <button class="btn btn-outline-success btn-sm rounded-circle flex-shrink-0" type="button" onclick="increaseQuantity(this)"><i class="fas fa-plus"></i></button>
                                <button class="btn btn-success rounded-pill fw-bold px-3 py-2 btn-sm flex-grow-1" type="button" onclick="addToCart(@product.Id, '@product.Name', this)"><i class="fas fa-shopping-cart me-2"></i>Thêm</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="fas fa-search text-muted fs-1 mb-3"></i>
                <p class="text-muted">Không tìm thấy sản phẩm nào phù hợp.</p>
            </div>
        }
    </div>

    <!-- Pagination - KHÔI PHỤC BẢN GỐC CỦA BẠN -->
    @if (ViewBag.TotalPages > 1)
    {
        var currentPage = (int)ViewBag.CurrentPage;
        var totalPages = (int)ViewBag.TotalPages;
        const int pageWindowSize = 5;
        var startPage = Math.Max(1, currentPage - 2);
        var endPage = Math.Min(totalPages, currentPage + 2);

        if (endPage - startPage + 1 < pageWindowSize)
        {
            if (startPage == 1) endPage = Math.Min(totalPages, startPage + pageWindowSize - 1);
            else if (endPage == totalPages) startPage = Math.Max(1, endPage - pageWindowSize + 1);
        }
        <nav class="mt-5" aria-label="Phân trang sản phẩm">
            <div class="pagination-shell">
                <ul class="pagination pagination-modern mb-0 justify-content-center align-items-center flex-wrap gap-1">
                @if (currentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link nav-btn" href="javascript:void(0)" onclick="changePage(1)" aria-label="Về trang đầu">&lt;&lt;</a>
                    </li>
                }

                @for (int p = startPage; p <= endPage; p++)
                {
                    <li class="page-item @(p == currentPage ? "active" : "")">
                        <a class="page-link" href="javascript:void(0)" onclick="changePage(@p)">@p</a>
                    </li>
                }

                @if (currentPage < totalPages)
                {
                    <li class="page-item">
                        <a class="page-link nav-btn" href="javascript:void(0)" onclick="changePage(@(currentPage + 1))" aria-label="Trang sau">&gt;&gt;</a>
                    </li>
                }
                </ul>
            </div>
        </nav>
    }
</div>
